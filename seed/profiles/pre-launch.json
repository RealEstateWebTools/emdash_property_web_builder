{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "Property Web Builder – Pre-launch",
		"description": "Minimal live presence while the full site is being prepared. Valuation form and contact page only — no property guides or blog.",
		"author": "EmDash"
	},

	"settings": {
		"title": "Your Agency Name",
		"tagline": "Local property advice while the full site is being prepared"
	},

	"collections": [
		{
			"slug": "posts",
			"label": "Posts",
			"labelSingular": "Post",
			"supports": ["drafts", "revisions", "search", "seo"],
			"commentsEnabled": true,
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "featured_image",
					"label": "Featured Image",
					"type": "image"
				},
				{
					"slug": "content",
					"label": "Content",
					"type": "portableText",
					"searchable": true
				},
				{
					"slug": "excerpt",
					"label": "Excerpt",
					"type": "text"
				}
			]
		},
		{
			"slug": "pages",
			"label": "Pages",
			"labelSingular": "Page",
			"supports": ["drafts", "revisions", "search"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "content",
					"label": "Content",
					"type": "portableText",
					"searchable": true
				},
				{
					"slug": "featured_section_heading",
					"label": "Featured Section Heading",
					"type": "string"
				},
				{
					"slug": "featured_collection_mode",
					"label": "Featured Collection Mode",
					"type": "select",
					"defaultValue": "split_featured",
					"validation": {
						"options": [
							"split_featured",
							"featured_any",
							"newest_any",
							"newest_sale",
							"newest_rental",
							"property_type_any",
							"property_type_sale",
							"property_type_rental"
						]
					}
				},
				{
					"slug": "featured_item_limit",
					"label": "Featured Item Limit",
					"type": "integer",
					"defaultValue": 3
				},
				{
					"slug": "featured_property_type",
					"label": "Featured Property Type Filter",
					"type": "string"
				},
				{
					"slug": "pre_featured_content",
					"label": "Homepage Content Before Featured Listings",
					"type": "portableText"
				},
				{
					"slug": "post_featured_content",
					"label": "Homepage Content After Featured Listings",
					"type": "portableText"
				},
				{
					"slug": "trust_content",
					"label": "Homepage Trust Content",
					"type": "portableText"
				}
			]
		}
	],

	"taxonomies": [
		{
			"name": "category",
			"label": "Categories",
			"labelSingular": "Category",
			"hierarchical": true,
			"collections": ["posts"],
			"terms": [
				{ "slug": "market-news", "label": "Market News" },
				{ "slug": "buying-guides", "label": "Buying Guides" },
				{ "slug": "selling-tips", "label": "Selling Tips" },
				{ "slug": "renting", "label": "Renting" },
				{ "slug": "lifestyle", "label": "Lifestyle" }
			]
		},
		{
			"name": "tag",
			"label": "Tags",
			"labelSingular": "Tag",
			"hierarchical": false,
			"collections": ["posts"],
			"terms": [
				{ "slug": "first-time-buyer", "label": "First Time Buyer" },
				{ "slug": "investment", "label": "Investment" },
				{ "slug": "mortgage", "label": "Mortgage" },
				{ "slug": "property-tips", "label": "Property Tips" },
				{ "slug": "local-area", "label": "Local Area" }
			]
		}
	],

	"bylines": [
		{
			"id": "byline-editorial",
			"slug": "editorial",
			"displayName": "Editorial Team"
		}
	],

	"menus": [
		{
			"name": "primary",
			"label": "Primary Navigation",
			"items": [
				{ "type": "custom", "label": "Home", "url": "/" },
				{ "type": "custom", "label": "Properties", "url": "/properties" },
				{ "type": "custom", "label": "Free Valuation", "url": "/valuation" },
				{ "type": "custom", "label": "Contact", "url": "/pages/contact" }
			]
		}
	],

	"widgetAreas": [
		{
			"name": "sidebar",
			"label": "Sidebar",
			"description": "Widget area displayed on article pages",
			"widgets": [
				{
					"type": "content",
					"title": "Free Valuation",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Thinking of selling? Get a free, no-obligation valuation from our team."
								}
							]
						}
					]
				}
			]
		},
		{
			"name": "footer",
			"label": "Footer",
			"description": "Widget area displayed in the site footer",
			"widgets": [
				{
					"type": "content",
					"title": "About Us",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Add a short agency description here so even the pre-launch site feels intentional and trustworthy."
								}
							]
						}
					]
				}
			]
		}
	],

	"sections": [
		{
			"slug": "free-valuation",
			"title": "Free Valuation",
			"description": "Call-to-action for booking a free property valuation",
			"keywords": ["valuation", "sell", "estimate", "cta"],
			"source": "theme",
			"content": [
				{
					"_type": "block",
					"style": "h3",
					"children": [{ "_type": "span", "text": "How much is your property worth?" }]
				},
				{
					"_type": "block",
					"style": "normal",
					"children": [
						{
							"_type": "span",
							"text": "Get a free, no-obligation valuation from our local property experts. We'll give you an honest assessment of your home's market value."
						}
					]
				}
			]
		}
	],

	"content": {
		"pages": [
			{
				"id": "homepage",
				"slug": "homepage",
				"status": "published",
				"data": {
					"title": "Welcome — We're Almost Ready",
					"featured_section_heading": "Latest listings",
					"featured_collection_mode": "featured_any",
					"featured_item_limit": 3,
					"featured_property_type": "",
					"pre_featured_content": [
						{
							"_type": "pwb-features",
							"heading": "Keep the pre-launch homepage focused",
							"feature1Icon": "01",
							"feature1Title": "Explain what is live now",
							"feature1Description": "Tell visitors they can already browse listings, book valuations, or contact the office directly.",
							"feature2Icon": "02",
							"feature2Title": "Set expectations clearly",
							"feature2Description": "Use this area to explain what the team covers before the full site and content plan are in place.",
							"feature3Icon": "03",
							"feature3Title": "Point to the next step",
							"feature3Description": "Keep the message direct so the homepage still converts while the full website is being prepared."
						}
					],
					"post_featured_content": [
						{
							"_type": "pwb-local-expertise",
							"eyebrow": "Before launch",
							"heading": "A focused first impression while the full site is prepared",
							"body": "This reusable block helps the pre-launch homepage explain the office, the local patch, and the type of enquiries the team can already help with.",
							"point1Label": "Coverage",
							"point1Value": "Your local market area",
							"point2Label": "Open for",
							"point2Value": "Valuations, listing enquiries, and buyer registrations",
							"point3Label": "Response",
							"point3Value": "Add your expected turnaround time",
							"buttonLabel": "Contact the team",
							"buttonHref": "/pages/contact"
						},
						{
							"_type": "pwb-cta",
							"heading": "Invite the first enquiry now",
							"body": "Use this final call to action to send visitors toward contact or valuation while the broader site is still being built.",
							"buttonLabel": "Contact the team",
							"buttonHref": "/pages/contact"
						}
					],
					"trust_content": [],
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Our full website is in progress. In the meantime, you can still browse live listings, request a valuation, or speak to the team directly."
								}
							]
						}
					]
				}
			},
			{
				"id": "contact",
				"slug": "contact",
				"status": "published",
				"data": {
					"title": "Contact Us",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Tell us what you need help with and we will come back with the right next step while the full website is being prepared."
								}
							]
						}
					]
				}
			}
		]
	}
}
