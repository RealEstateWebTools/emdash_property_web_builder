diff --git a/src/components/plugin-block-attrs.ts b/src/components/plugin-block-attrs.ts
new file mode 100644
index 0000000000000000000000000000000000000000..4834ae362ea5c5d6bd05194cf85dcd3376fc36e1
--- /dev/null
+++ b/src/components/plugin-block-attrs.ts
@@ -0,0 +1,53 @@
+export interface PortableTextPluginBlock {
+	_type: string;
+	_key: string;
+	[key: string]: unknown;
+}
+
+export interface PluginBlockAttrs extends Record<string, unknown> {
+	blockType: string;
+	blockKey?: string;
+	id?: string;
+	data?: Record<string, unknown>;
+}
+
+function isPlainObject(value: unknown): value is Record<string, unknown> {
+	return typeof value === "object" && value !== null && !Array.isArray(value);
+}
+
+function omitPrivateKeys(value: Record<string, unknown>): Record<string, unknown> {
+	return Object.fromEntries(Object.entries(value).filter(([key]) => !key.startsWith("_")));
+}
+
+export function portableTextPluginBlockToAttrs(block: PortableTextPluginBlock): PluginBlockAttrs {
+	const { _type, _key, id, url, ...rest } = block;
+	return {
+		blockType: typeof _type === "string" && _type ? _type : "embed",
+		blockKey: _key,
+		id: typeof id === "string" ? id : typeof url === "string" ? url : "",
+		data: omitPrivateKeys(rest),
+	};
+}
+
+export function pluginBlockAttrsToPortableTextBlock(
+	attrs: Record<string, unknown> | undefined,
+	generateKey: () => string,
+): PortableTextPluginBlock {
+	const input = isPlainObject(attrs) ? attrs : {};
+	const { blockType, blockKey, type, id, data, ...rest } = input;
+	const resolvedType =
+		typeof blockType === "string" && blockType
+			? blockType
+			: typeof type === "string" && type
+				? type
+				: "embed";
+	const resolvedKey = typeof blockKey === "string" && blockKey ? blockKey : generateKey();
+
+	return {
+		...(isPlainObject(data) ? data : {}),
+		...omitPrivateKeys(rest),
+		_type: resolvedType,
+		_key: resolvedKey,
+		id: typeof id === "string" ? id : "",
+	};
+}
