diff --git a/src/components/plugin-block-attrs.ts b/src/components/plugin-block-attrs.ts
new file mode 100644
index 0000000000000000000000000000000000000000..11f14026e8dd9a23de888ccba0cf81f1ede444e2
--- /dev/null
+++ b/src/components/plugin-block-attrs.ts
@@ -0,0 +1,51 @@
+export interface PortableTextPluginBlock {
+	_type: string;
+	_key: string;
+	[key: string]: unknown;
+}
+
+export interface PluginBlockAttrs extends Record<string, unknown> {
+	blockType: string;
+	blockKey?: string;
+}
+
+function isPlainObject(value: unknown): value is Record<string, unknown> {
+	return typeof value === "object" && value !== null && !Array.isArray(value);
+}
+
+export function portableTextPluginBlockToAttrs(block: PortableTextPluginBlock): PluginBlockAttrs {
+	const { _type, _key, ...rest } = block;
+	return {
+		blockType: _type,
+		blockKey: _key,
+		...rest,
+	};
+}
+
+export function pluginBlockAttrsToPortableTextBlock(
+	attrs: Record<string, unknown> | undefined,
+	generateKey: () => string,
+): PortableTextPluginBlock {
+	const input = isPlainObject(attrs) ? attrs : {};
+	const {
+		blockType,
+		blockKey,
+		type,
+		...rest
+	} = input;
+
+	const resolvedType =
+		typeof blockType === "string" && blockType
+			? blockType
+			: typeof type === "string" && type
+				? type
+				: "embed";
+
+	const resolvedKey = typeof blockKey === "string" && blockKey ? blockKey : generateKey();
+
+	return {
+		_type: resolvedType,
+		_key: resolvedKey,
+		...rest,
+	};
+}
