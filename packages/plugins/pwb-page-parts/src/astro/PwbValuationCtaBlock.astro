---
import { normalizeLocale, t } from "../i18n.js";

const { node } = Astro.props;
const locale = normalizeLocale(Astro.currentLocale);

const eyebrow = typeof node?.eyebrow === "string" && node.eyebrow.trim() ? node.eyebrow : t(locale, "valuationEyebrow");
const heading = typeof node?.heading === "string" && node.heading.trim() ? node.heading : t(locale, "valuationHeading");
const body = typeof node?.body === "string" && node.body.trim() ? node.body : t(locale, "valuationBody");
const buttonLabel = typeof node?.buttonLabel === "string" && node.buttonLabel.trim() ? node.buttonLabel : t(locale, "valuationButton");
const valuationHref = typeof node?.valuationHref === "string" && node.valuationHref.trim() ? node.valuationHref : "/valuation";
---

<section class="pwb-valuation-cta">
  <div class="pwb-valuation-cta__body">
    {eyebrow && <p class="pwb-valuation-cta__eyebrow">{eyebrow}</p>}
    <h3 class="pwb-valuation-cta__heading">{heading}</h3>
    <p class="pwb-valuation-cta__text">{body}</p>
  </div>
  <div class="pwb-valuation-cta__actions">
    <a href={valuationHref} class="pwb-valuation-cta__btn">{buttonLabel}</a>
  </div>
</section>

<style>
  .pwb-valuation-cta {
    margin: 2rem 0;
    border-radius: 1.25rem;
    background:
      linear-gradient(135deg, rgba(185, 138, 78, 0.14) 0%, rgba(252, 250, 247, 0.9) 60%),
      var(--color-surface, #f8f5ef);
    border: 1px solid rgba(185, 138, 78, 0.28);
    padding: 2rem 2rem 1.75rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: center;
  }

  .pwb-valuation-cta__eyebrow {
    margin: 0 0 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent, #936f2f);
  }

  .pwb-valuation-cta__heading {
    margin: 0 0 0.6rem;
    font-size: clamp(1.3rem, 2.4vw, 1.9rem);
    line-height: 1.1;
    color: var(--color-primary, #16354c);
  }

  .pwb-valuation-cta__text {
    margin: 0;
    color: var(--color-text-soft, #5a6a79);
    line-height: 1.6;
    max-width: 52ch;
  }

  .pwb-valuation-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.6rem;
    border-radius: 999px;
    background: var(--color-accent, #936f2f);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    white-space: nowrap;
    border: 1px solid color-mix(in srgb, var(--color-accent, #936f2f) 68%, black);
    transition: opacity 0.18s ease;
  }

  .pwb-valuation-cta__btn:hover {
    opacity: 0.88;
  }

  @media (max-width: 768px) {
    .pwb-valuation-cta {
      grid-template-columns: 1fr;
    }

    .pwb-valuation-cta__btn {
      width: 100%;
    }
  }
</style>
