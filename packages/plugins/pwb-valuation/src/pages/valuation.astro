---
/**
 * Injected route: /valuation
 *
 * This page is injected by pwbValuationIntegration() — it does not live in
 * src/pages/. Virtual modules let it import from the host site without
 * hardcoded relative paths:
 *
 *   virtual:pwb-valuation/layout     → host's BaseLayout.astro
 *   virtual:pwb-valuation/pwb-client → host's createPwbClient
 *   virtual:pwb-valuation/config     → integration options
 *
 * The Vite plugin in integration.js resolves these at build time.
 */

// @ts-ignore — virtual modules are resolved by the Vite plugin at build time
import BaseLayout from "virtual:pwb-valuation/layout";
// @ts-ignore
import { createPwbClient } from "virtual:pwb-valuation/pwb-client";
// @ts-ignore
import { config } from "virtual:pwb-valuation/config";

let success = false;
let errorMessage = "";

if (Astro.request.method === "POST") {
  let formData;
  try {
    formData = await Astro.request.formData();
  } catch {
    errorMessage = "Could not read form submission.";
  }

  if (formData) {
    const body = {
      name: formData.get("name"),
      email: formData.get("email"),
      phone: formData.get("phone"),
      address: formData.get("address"),
      notes: formData.get("notes"),
    };

    const submitUrl = new URL(
      "/_emdash/api/plugins/pwb-valuation/submit",
      Astro.url,
    );

    try {
      const res = await fetch(submitUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        return Astro.redirect(`${config.basePath}/valuation?sent=1`);
      } else {
        const json = await res.json().catch(() => ({}));
        errorMessage = json.error ?? "Submission failed. Please try again.";
      }
    } catch {
      errorMessage = "Network error. Please try again.";
    }
  }
}

const sent = Astro.url.searchParams.get("sent") === "1";
const client = createPwbClient();
const site = await client.getSiteDetails();
---

<BaseLayout site={site} title="Request a Valuation">
  <div class="valuation-page">
    <div class="valuation-inner">
      <h1>Request a Property Valuation</h1>
      <p class="valuation-intro">
        Get a free, no-obligation valuation from our team. Fill in your details
        below and we'll be in touch shortly.
      </p>

      {sent && (
        <div class="valuation-success" role="alert">
          <strong>Thank you!</strong> Your valuation request has been received.
          We'll be in touch soon.
        </div>
      )}

      {errorMessage && (
        <div class="valuation-error" role="alert">
          {errorMessage}
        </div>
      )}

      {!sent && (
        <form method="POST" class="valuation-form">
          <div class="form-row">
            <label for="val-name">Full name <span aria-hidden="true">*</span></label>
            <input
              id="val-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              placeholder="Jane Smith"
            />
          </div>

          <div class="form-row">
            <label for="val-email">Email address <span aria-hidden="true">*</span></label>
            <input
              id="val-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="jane@example.com"
            />
          </div>

          <div class="form-row">
            <label for="val-phone">Phone number</label>
            <input
              id="val-phone"
              name="phone"
              type="tel"
              autocomplete="tel"
              placeholder="+1 555 000 0000"
            />
          </div>

          <div class="form-row">
            <label for="val-address">Property address <span aria-hidden="true">*</span></label>
            <input
              id="val-address"
              name="address"
              type="text"
              required
              placeholder="123 Main St, City"
            />
          </div>

          <div class="form-row">
            <label for="val-notes">Additional notes</label>
            <textarea
              id="val-notes"
              name="notes"
              rows="4"
              placeholder="Anything else you'd like us to know…"
            ></textarea>
          </div>

          <button type="submit" class="valuation-submit">
            Request Valuation
          </button>
        </form>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .valuation-page {
    max-width: 700px;
    margin: 0 auto;
    padding: 3rem var(--spacing-page, 1.5rem);
  }

  .valuation-inner h1 {
    margin-bottom: 0.5rem;
  }

  .valuation-intro {
    color: var(--color-text-muted, #666);
    margin-bottom: 2rem;
  }

  .valuation-success {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #166534;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .valuation-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #991b1b;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .valuation-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-row label {
    font-weight: 500;
    font-size: 0.9rem;
  }

  .form-row input,
  .form-row textarea {
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: 0.375rem;
    font-size: 1rem;
    width: 100%;
    box-sizing: border-box;
  }

  .form-row input:focus,
  .form-row textarea:focus {
    outline: 2px solid var(--color-primary, #2563eb);
    outline-offset: 1px;
  }

  .valuation-submit {
    align-self: flex-start;
    background: var(--color-primary, #2563eb);
    color: #fff;
    border: none;
    border-radius: 0.375rem;
    padding: 0.7rem 1.75rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
  }

  .valuation-submit:hover {
    opacity: 0.9;
  }
</style>
