# The URL of your PWB backend — no trailing slash
PWB_API_URL=http://localhost:3000

# Active colour palette (optional — defaults to "default")
# One of: default | gold | luxury | mediterranean | coastal | countryside | urban | nordic
# Change this and restart the dev server to switch the site theme.
PUBLIC_PALETTE=default

# Seed profile used by `pnpm seed` (optional — defaults to "full")
# Set to "minimal" for a faster seed with fewer demo records.
# SEED_PROFILE=full
