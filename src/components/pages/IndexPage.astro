---
import { getEmDashEntry } from 'emdash'
import { PortableText } from 'emdash/ui'
import { createPwbClient } from '../../lib/pwb/client'
import { formatPropertyCard } from '../../lib/pwb/formatters'
import BaseLayout from '../../layouts/BaseLayout.astro'
import PropertyGrid from '../PropertyGrid.astro'
import { localePath, translateLabel } from '../../lib/locale'

interface Props {
  locale: string
}

const { locale } = Astro.props

const { entry: homepage, cacheHint } = await getEmDashEntry('pages', 'homepage', { locale })
Astro.cache.set(cacheHint)

const client = createPwbClient(locale)
const [site, results] = await Promise.all([
  client.getSiteDetails(),
  client.searchProperties({ featured: 'true', per_page: 6 }),
])

const cards = results.data.map(formatPropertyCard)
---

<BaseLayout site={site} title={homepage?.data.title}>
  <section class="hero">
    <div class="hero__image-wrapper">
      <img src="/hero-bg.png" alt="Luxury Home" class="hero__image" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__inner">
      <h1 class="hero__heading" {...homepage?.edit.title}>
        {homepage?.data.title ?? 'Find Your Dream Property'}
      </h1>
      {homepage?.data.content && (
        <div class="hero__tagline" {...homepage.edit.content}>
          <PortableText value={homepage.data.content} />
        </div>
      )}
      <div class="hero__search">
        <form action={localePath(locale, '/properties')} method="get" class="hero-search-form">
          <div class="hero-search-form__field">
            <select name="mode" class="hero-search-form__input">
              <option value="">{translateLabel(locale, 'All Types')}</option>
              <option value="sale">{translateLabel(locale, 'Buy')}</option>
              <option value="rental">{translateLabel(locale, 'Rent')}</option>
            </select>
          </div>
          <div class="hero-search-form__field hero-search-form__field--location">
            <input type="text" name="location" placeholder={translateLabel(locale, 'Enter city or neighborhood...')} class="hero-search-form__input" />
          </div>
          <button type="submit" class="hero-search-form__submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            {translateLabel(locale, 'Search')}
          </button>
        </form>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar__inner">
      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
        </div>
        <div class="trust-bar__content">
          <span class="trust-bar__number">500+</span>
          <span class="trust-bar__label">{translateLabel(locale, 'Properties Listed')}</span>
        </div>
      </div>
      <div class="trust-bar__divider"></div>
      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="trust-bar__content">
          <span class="trust-bar__number">98%</span>
          <span class="trust-bar__label">{translateLabel(locale, 'Client Satisfaction')}</span>
        </div>
      </div>
      <div class="trust-bar__divider"></div>
      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div class="trust-bar__content">
          <span class="trust-bar__number">10+</span>
          <span class="trust-bar__label">{translateLabel(locale, 'Years Experience')}</span>
        </div>
      </div>
      <div class="trust-bar__divider"></div>
      <div class="trust-bar__item">
        <div class="trust-bar__icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="trust-bar__content">
          <span class="trust-bar__number">50+</span>
          <span class="trust-bar__label">{translateLabel(locale, 'Expert Agents')}</span>
        </div>
      </div>
    </div>
  </div>

  {cards.length > 0 && (
    <section class="featured-section">
      <div class="featured-section__header">
        <h2 {...homepage?.edit.featured_section_heading}>
          {homepage?.data.featured_section_heading ?? 'Featured Properties'}
        </h2>
        <p class="featured-section__subtitle">{translateLabel(locale, 'Handpicked properties for you')}</p>
      </div>
      <PropertyGrid cards={cards} />
      <div class="featured-section__cta">
        <a href={localePath(locale, '/properties')} class="btn btn-primary">{translateLabel(locale, 'View All Properties')}</a>
      </div>
    </section>
  )}

  <section class="cta-banner">
    <div class="cta-banner__inner">
      <div class="cta-banner__text">
        <h2>{translateLabel(locale, 'Ready to Sell or Let Your Property?')}</h2>
        <p>{translateLabel(locale, 'Get a free valuation from our expert team today.')}</p>
      </div>
      <div class="cta-banner__actions">
        <a href={localePath(locale, '/contact')} class="btn btn-cta-primary">{translateLabel(locale, 'Contact Us')}</a>
      </div>
    </div>
  </section>
</BaseLayout>
<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    padding: 10rem var(--spacing-page) 10rem;
    overflow: hidden;
    color: #fff;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero__image-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(15, 23, 42, 0.4), rgba(15, 23, 42, 0.8));
    z-index: 1;
  }
  .hero__inner {
    position: relative;
    z-index: 10;
    max-width: 900px;
    width: 100%;
    text-align: center;
  }
  .hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 2rem;
    color: #fff;
    letter-spacing: -0.02em;
    text-shadow: 0 4px 12px rgba(0,0,0,0.3);
  }
  .hero__tagline {
    font-size: var(--text-xl);
    color: rgba(255,255,255,0.9);
    margin-bottom: 3.5rem;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
    text-shadow: 0 2px 4px rgba(0,0,0,0.2);
  }

  /* ── Hero Search Box ─────────────────────────────────────────── */
  .hero__search {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    padding: 1rem;
    border-radius: var(--radius-md);
    max-width: 800px;
    margin: 0 auto;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  .hero-search-form {
    display: flex;
    background: #fff;
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
  }
  .hero-search-form__field {
    flex: 1;
    position: relative;
    border-right: 1px solid var(--color-border);
  }
  .hero-search-form__field--location {
    flex: 2;
  }
  .hero-search-form__input {
    width: 100%;
    border: none;
    padding: 1.25rem 1.5rem;
    font-size: var(--text-base);
    color: var(--color-text);
    background: transparent;
    outline: none;
    font-weight: 500;
  }
  .hero-search-form__input:focus {
    background: var(--color-bg-soft);
  }
  select.hero-search-form__input {
    appearance: none;
    cursor: pointer;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23333' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 1rem center;
    background-size: 1rem;
    padding-right: 2.5rem;
  }
  .hero-search-form__submit {
    background: var(--color-primary);
    color: #fff;
    border: none;
    padding: 0 2.5rem;
    font-size: var(--text-lg);
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: background 0.2s ease;
  }
  .hero-search-form__submit:hover {
    background: var(--color-primary-dark);
  }

  @media (max-width: 768px) {
    .hero__search {
      background: transparent;
      backdrop-filter: none;
      padding: 0;
      border: none;
    }
    .hero-search-form {
      flex-direction: column;
      border-radius: var(--radius-md);
    }
    .hero-search-form__field {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
    .hero-search-form__submit {
      padding: 1.25rem;
      justify-content: center;
    }
  }

  /* ── Trust Bar ────────────────────────────────────────────────── */
  .trust-bar {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    margin-top: -4rem;
    z-index: 20;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.05);
  }
  .trust-bar__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem var(--spacing-page);
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 0;
  }
  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    justify-content: center;
  }
  .trust-bar__icon {
    width: 48px;
    height: 48px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }
  .trust-bar__number {
    display: block;
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }
  .trust-bar__label {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
    margin-top: 0.25rem;
  }
  .trust-bar__divider {
    width: 1px;
    height: 3rem;
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* ── Featured Section ─────────────────────────────────────────── */
  .featured-section {
    padding: 8rem var(--spacing-page);
    background: var(--color-bg-soft);
  }
  .featured-section__header {
    text-align: center;
    margin-bottom: 5rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .featured-section__header h2 {
    font-family: var(--font-serif);
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .featured-section__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }
  .featured-section__cta {
    text-align: center;
    margin-top: 5rem;
  }

  @media (max-width: 1024px) {
    .trust-bar__inner {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }
    .trust-bar__divider { display: none; }
    .trust-bar__item { justify-content: flex-start; }
  }

  @media (max-width: 640px) {
    .trust-bar__inner {
      grid-template-columns: 1fr;
    }
    .hero { min-height: 60vh; padding: 6rem var(--spacing-page) 4rem; }
    .hero__heading { font-size: 3rem; }
    .trust-bar { margin-top: 0; border-radius: 0; }
  }

  /* ── CTA Banner ────────────────────────────────────────────────── */
  .cta-banner {
    background: var(--color-primary);
    padding: 5rem var(--spacing-page);
    color: #fff;
    text-align: center;
  }
  .cta-banner__inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }
  .cta-banner__text h2 {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 800;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }
  .cta-banner__text p {
    font-size: var(--text-lg);
    color: rgba(255,255,255,0.9);
  }
  .btn-cta-primary {
    background: #fff;
    color: var(--color-primary);
    padding: 1rem 2.5rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    font-size: var(--text-lg);
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    white-space: nowrap;
  }
  .btn-cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0,0,0,0.15);
  }
  @media (min-width: 768px) {
    .cta-banner__inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
    .cta-banner__text h2 {
      margin-bottom: 0.5rem;
    }
  }
</style>
