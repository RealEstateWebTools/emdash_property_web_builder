---
import { getEmDashEntry } from 'emdash'
import { PortableText } from 'emdash/ui'
import { createPwbClient } from '../../lib/pwb/client'
import { fallbackSite } from '../../lib/pwb/fallback-site'
import {
  loadHomepageListingGroups,
  readHomepageMerchandisingConfig,
} from '../../lib/homepage-merchandising'
import BaseLayout from '../../layouts/BaseLayout.astro'
import PropertyGrid from '../PropertyGrid.astro'
import { localePath, translateLabel } from '../../lib/locale'

interface Props {
  locale: string
}

const { locale } = Astro.props

const { entry: homepage, cacheHint } = await getEmDashEntry('pages', 'homepage', { locale })
Astro.cache.set(cacheHint)
const homepageData = (homepage?.data ?? undefined) as Record<string, unknown> | undefined
const preFeaturedContent = Array.isArray(homepageData?.pre_featured_content) ? homepageData.pre_featured_content : []
const postFeaturedContent = Array.isArray(homepageData?.post_featured_content)
  ? homepageData.post_featured_content
  : Array.isArray(homepageData?.trust_content)
    ? homepageData.trust_content
    : []

let site = fallbackSite
let featuredGroups: Awaited<ReturnType<typeof loadHomepageListingGroups>> = []
const merchandising = readHomepageMerchandisingConfig(homepageData)

try {
  const client = createPwbClient(locale)
  ;[site, featuredGroups] = await Promise.all([
    client.getSiteDetails(),
    loadHomepageListingGroups(client, merchandising),
  ])
} catch {
  site = fallbackSite
  featuredGroups = []
}

const hasFeaturedInventory = featuredGroups.length > 0

---

<BaseLayout site={site} title={homepage?.data.title}>
  <section class="hero">
    <div class="hero__image-wrapper">
      <img src="/hero-bg.png" alt="Luxury home exterior with pool" class="hero__image" />
      <div class="hero__overlay"></div>
    </div>

    <div class="hero__inner">
      <div class="hero__copy">
        <p class="hero__eyebrow">{translateLabel(locale, 'Boutique property advisory')}</p>
        <h1 class="hero__heading" {...homepage?.edit.title}>
          {homepage?.data.title ?? 'Homes chosen with more care'}
        </h1>
        {homepage?.data.content && (
          <div class="hero__tagline" {...homepage.edit.content}>
            <PortableText value={homepage.data.content} />
          </div>
        )}

        <div class="hero__search">
          <form action={localePath(locale, '/properties')} method="get" class="hero-search-form">
            <div class="hero-search-form__field">
              <label class="hero-search-form__label" for="hero-mode">{translateLabel(locale, 'Looking to')}</label>
              <select id="hero-mode" name="sale_or_rental" class="hero-search-form__input">
                <option value="">{translateLabel(locale, 'All Types')}</option>
                <option value="sale">{translateLabel(locale, 'Buy')}</option>
                <option value="rental">{translateLabel(locale, 'Rent')}</option>
              </select>
            </div>
            <div class="hero-search-form__field hero-search-form__field--location">
              <label class="hero-search-form__label" for="hero-location">{translateLabel(locale, 'Location')}</label>
              <input
                id="hero-location"
                type="text"
                name="location"
                placeholder={translateLabel(locale, 'Enter city or neighborhood...')}
                class="hero-search-form__input"
              />
            </div>
            <button type="submit" class="hero-search-form__submit">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              {translateLabel(locale, 'Search')}
            </button>
          </form>
        </div>

        <div class="hero__ctas">
          <a href={localePath(locale, '/properties')} class="hero__cta-btn hero__cta-btn--primary">
            {translateLabel(locale, 'Browse Properties')}
          </a>
          <a href={localePath(locale, '/contact')} class="hero__cta-btn hero__cta-btn--ghost">
            {translateLabel(locale, 'Contact Us')}
          </a>
        </div>

        <div class="hero__highlights" aria-label={translateLabel(locale, 'Quick brand highlights')}>
          <span>{translateLabel(locale, '500+ homes marketed')}</span>
          <span>{translateLabel(locale, 'Faster shortlists, better fit')}</span>
          <span>{translateLabel(locale, 'Local market sense, cleaner presentation')}</span>
        </div>
      </div>
    </div>
  </section>

  {preFeaturedContent.length > 0 && (
    <section class="homepage-modules homepage-modules--pre-featured">
      <PortableText value={preFeaturedContent} />
    </section>
  )}

  {hasFeaturedInventory && (
    <section class="inventory-section">
      <div class="section-heading section-heading--left">
        <p class="section-heading__eyebrow">{translateLabel(locale, 'Featured homes')}</p>
        <h2 {...homepage?.edit.featured_section_heading}>
          {homepage?.data.featured_section_heading ?? 'Featured Properties'}
        </h2>
        <p>{translateLabel(locale, 'Selected listings presented with the same editorial care we bring to the rest of the brand.')}</p>
      </div>

      {featuredGroups.map((group) => (
        <div class="inventory-group">
          <div class="inventory-group__header">
            <div>
              <p class="inventory-group__eyebrow">{translateLabel(locale, group.eyebrow)}</p>
              <h3>{translateLabel(locale, group.title)}</h3>
            </div>
            <a href={localePath(locale, group.href)} class="inventory-group__link">
              {translateLabel(locale, 'View All Properties')}
            </a>
          </div>
          <PropertyGrid cards={group.cards} />
        </div>
      ))}
    </section>
  )}

  {postFeaturedContent.length > 0 && (
    <section class="homepage-modules homepage-modules--post-featured">
      <PortableText value={postFeaturedContent} />
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: var(--space-section-lg) var(--spacing-page) var(--space-section-md);
    overflow: hidden;
    color: var(--color-on-dark);
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
  }

  .hero__image-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.04);
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(9, 26, 39, 0.88) 0%, rgba(9, 26, 39, 0.62) 48%, rgba(9, 26, 39, 0.38) 100%),
      linear-gradient(180deg, rgba(9, 26, 39, 0.22) 0%, rgba(9, 26, 39, 0.66) 100%);
    z-index: 1;
  }

  .hero__inner {
    position: relative;
    z-index: 10;
    width: min(100%, 76rem);
    margin: 0 auto;
  }

  .hero__copy {
    max-width: 44rem;
  }

  .hero__eyebrow {
    margin: 0 0 var(--spacing-4);
    font-size: var(--text-xs);
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-gold);
    font-weight: 700;
  }

  .hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 8vw, 6.4rem);
    line-height: 0.95;
    margin-bottom: var(--spacing-6);
    color: var(--color-on-dark);
    letter-spacing: -0.04em;
  }

  .hero__tagline {
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    color: rgba(246, 242, 235, 0.88);
    margin-bottom: var(--spacing-8);
    max-width: 38rem;
    line-height: 1.75;
  }

  .hero__tagline :global(p) {
    margin: 0;
  }

  .hero__search {
    background: rgba(247, 242, 234, 0.14);
    backdrop-filter: blur(16px);
    padding: var(--spacing-3);
    border-radius: var(--radius-lg);
    max-width: 54rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow: var(--shadow-hero-panel);
  }

  .hero-search-form {
    display: grid;
    grid-template-columns: 13rem minmax(0, 1fr) auto;
    background: rgba(252, 248, 243, 0.96);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .hero-search-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.15rem;
    border-right: 1px solid rgba(22, 53, 76, 0.12);
  }

  .hero-search-form__field--location {
    min-width: 0;
  }

  .hero-search-form__label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-soft);
    font-weight: 700;
  }

  .hero-search-form__input {
    width: 100%;
    border: none;
    padding: 0;
    font-size: var(--text-base);
    color: var(--color-text);
    background: transparent;
    outline: none;
    font-weight: 600;
    min-height: 1.75rem;
  }

  .hero-search-form__input::placeholder {
    color: var(--color-text-muted);
  }

  .hero-search-form__input:focus {
    background: transparent;
  }

  select.hero-search-form__input {
    appearance: none;
    cursor: pointer;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2316354c' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right center;
    background-size: 1rem;
    padding-right: 1.4rem;
  }

  .hero-search-form__submit {
    background: var(--color-accent);
    color: var(--color-on-accent);
    border: none;
    padding: 0 1.75rem;
    font-size: var(--text-base);
    font-weight: 700;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: background var(--transition-base), transform var(--transition-base);
  }

  .hero-search-form__submit:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    margin-top: var(--spacing-6);
    flex-wrap: wrap;
  }

  .hero__cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 12rem;
    padding: 0.95rem 1.6rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: var(--text-base);
    text-decoration: none;
    transition: transform var(--transition-base), background var(--transition-base), color var(--transition-base), border-color var(--transition-base);
  }

  .hero__cta-btn--primary {
    background: var(--color-surface-strong);
    color: var(--color-primary);
    border: 1px solid var(--color-surface-strong);
    box-shadow: var(--shadow-md);
  }

  .hero__cta-btn--primary:hover {
    transform: translateY(-2px);
    background: var(--color-surface);
  }

  .hero__cta-btn--ghost {
    background: transparent;
    color: var(--color-on-dark);
    border: 1px solid rgba(255, 255, 255, 0.55);
  }

  .hero__cta-btn--ghost:hover {
    border-color: var(--color-on-dark);
    background: rgba(255, 255, 255, 0.08);
  }

  .hero__highlights {
    margin-top: var(--spacing-8);
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__highlights span {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(246, 242, 235, 0.92);
    font-size: var(--text-sm);
  }

  .inventory-section,
  .homepage-modules {
    padding-left: var(--spacing-page);
    padding-right: var(--spacing-page);
  }

  .homepage-modules--pre-featured {
    padding-top: var(--space-section-md);
    padding-bottom: var(--space-section-md);
    background:
      radial-gradient(circle at top left, rgba(185, 138, 78, 0.12), transparent 32%),
      linear-gradient(180deg, var(--color-bg-soft) 0%, var(--color-surface) 100%);
  }

  .section-heading {
    width: min(100%, 46rem);
    margin: 0 auto 3rem;
    text-align: center;
  }

  .section-heading--left {
    margin-left: auto;
    margin-right: auto;
    width: min(100%, 72rem);
    text-align: left;
  }

  .section-heading__eyebrow,
  .inventory-group__eyebrow {
    margin: 0 0 0.75rem;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    font-weight: 700;
  }

  .section-heading h2,
  .inventory-group__header h3 {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4vw, 3.75rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-primary);
  }

  .section-heading p {
    color: var(--color-text-soft);
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .inventory-section {
    padding-top: var(--space-section-md);
    padding-bottom: var(--space-section-lg);
    background: var(--color-bg);
  }

  .inventory-group {
    width: min(100%, 72rem);
    margin: 0 auto;
  }

  .inventory-group + .inventory-group {
    margin-top: var(--space-section-sm);
  }

  .inventory-group__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .inventory-group__link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 700;
    white-space: nowrap;
  }

  .inventory-group__link:hover {
    color: var(--color-primary);
  }

  .inventory-section :global(.property-grid) {
    padding: 0;
  }

  .homepage-modules--post-featured {
    padding-top: 0;
    padding-bottom: var(--space-section-lg);
    background:
      linear-gradient(180deg, rgba(244, 238, 228, 0.92) 0%, rgba(244, 238, 228, 0.52) 100%),
      var(--color-bg-soft);
  }

  @media (max-width: 1024px) {
    .hero__heading {
      max-width: 12ch;
    }

    .inventory-group__header {
      align-items: start;
      flex-direction: column;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: var(--space-section-lg);
    }

    .hero-search-form {
      grid-template-columns: 1fr;
    }

    .hero-search-form__field {
      border-right: none;
      border-bottom: 1px solid rgba(22, 53, 76, 0.12);
    }

    .hero-search-form__submit {
      padding: 1rem 1.25rem;
      justify-content: center;
    }

  }

  @media (max-width: 640px) {
    .hero__heading {
      font-size: clamp(2.8rem, 16vw, 4.5rem);
    }

    .hero__ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__cta-btn {
      width: 100%;
    }

    .inventory-group__link {
      white-space: normal;
    }
  }
</style>
