---
import { getEmDashCollection } from "emdash";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../PostCard.astro";
import { createPwbClient } from "../../lib/pwb/client";
import { fallbackSite } from "../../lib/pwb/fallback-site";
import { getReadingTime } from "../../utils/reading-time";
import { matchesQuery, buildSearchSummary } from "../../lib/search/post-search";
import { entrySlug, localePath, translateLabel } from "../../lib/locale";

interface Props {
  locale: string
}

const { locale } = Astro.props

const query = Astro.url.searchParams.get("q")?.trim() || "";

const { entries: allPosts } = await getEmDashCollection("posts", { locale });

let site = fallbackSite;
try {
	site = await createPwbClient(locale).getSiteDetails();
} catch {
	site = fallbackSite;
}

const results = query ? allPosts.filter((p) => matchesQuery(p, query)) : [];

const searchAction = localePath(locale, '/search')
const searchLabel = translateLabel(locale, 'Search')
const searchDescription = translateLabel(locale, 'Search blog posts')
const searchPlaceholder = translateLabel(locale, 'Search posts...')
const searchHint = translateLabel(locale, 'Enter a search term to find posts.')
const searchSummary = buildSearchSummary(query, results.length, locale)
---

<BaseLayout
	site={site}
	title={query ? `${searchLabel}: ${query}` : searchLabel}
	description={searchDescription}
>
	<section class="search-page">
		<h1 class="search-title">{searchLabel}</h1>

		<form method="get" action={searchAction} class="search-form">
			<input
				type="search"
				name="q"
				value={query}
				placeholder={searchPlaceholder}
				class="search-input"
				autofocus
			/>
			<button type="submit" class="search-button">{searchLabel}</button>
		</form>

		{
			searchSummary && (
				<p class="search-summary">
					{searchSummary}
				</p>
			)
		}

		{
			results.length > 0 && (
				<div class="search-results">
					{results.map((post) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={localePath(locale, `/posts/${entrySlug(post.id)}`)}
							date={post.data.publishedAt ?? undefined}
							readingTime={getReadingTime(post.data.content)}
						/>
					))}
				</div>
			)
		}

		{!query && <p class="search-hint">{searchHint}</p>}
	</section>
</BaseLayout>

<style>
	.search-page {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	.search-title {
		font-size: var(--font-size-2xl);
		margin-bottom: var(--spacing-6);
	}

	.search-form {
		display: flex;
		gap: var(--spacing-2);
		margin-bottom: var(--spacing-8);
	}

	.search-input {
		flex: 1;
		padding: var(--spacing-2) var(--spacing-4);
		font-size: var(--font-size-base);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		background: var(--color-bg);
		color: var(--color-text);
	}

	.search-input:focus {
		outline: none;
		border-color: var(--color-accent);
	}

	.search-button {
		padding: var(--spacing-2) var(--spacing-6);
		font-size: var(--font-size-base);
		background: var(--color-accent);
		color: var(--color-on-accent);
		border: none;
		border-radius: var(--radius);
		cursor: pointer;
		font-weight: 500;
	}

	.search-button:hover {
		opacity: 0.9;
	}

	.search-summary {
		color: var(--color-muted);
		margin-bottom: var(--spacing-6);
	}

	.search-hint {
		color: var(--color-muted);
	}

	.search-results {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-8);
	}
</style>
