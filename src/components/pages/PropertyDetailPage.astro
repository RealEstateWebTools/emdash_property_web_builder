---
import { createPwbClient } from '../../lib/pwb/client'
import { formatPropertyDetail } from '../../lib/pwb/detail-formatter'
import { htmlToMetaDescription } from '../../lib/pwb/formatters'
import { fallbackSite } from '../../lib/pwb/fallback-site'
import { buildPropertyCtaModel } from '../../lib/property-cta'
import { readSiteProfileSettingsFromDb } from '../../lib/site-profile'
import BaseLayout from '../../layouts/BaseLayout.astro'
import PropertyDetail from '../PropertyDetail.astro'
import ContactForm from '../ContactForm.astro'
import SimilarProperties from '../SimilarProperties.astro'
import { localePath, translateLabel } from '../../lib/locale'

interface Props {
  locale: string
  slug: string
}

const { locale, slug } = Astro.props
const safeSlug = slug ?? null

const client = createPwbClient(locale)

let property = null
let site = fallbackSite
const siteProfile = await readSiteProfileSettingsFromDb(Astro.locals.emdash?.db)

if (safeSlug) {
  try {
    ;[property, site] = await Promise.all([
      client.getProperty(safeSlug),
      client.getSiteDetails(),
    ])
  } catch {
    Astro.response.status = 404
  }
} else {
  Astro.response.status = 404
}

const detail = property ? formatPropertyDetail(property) : null
const similarListing = property?.page_contents.find(
  (pc) => pc.page_part_key === 'summary_listings_part/similar_properties'
)
const similarProperties = similarListing?.summ_listings ?? []
const canonicalPath = localePath(locale, `/properties/${safeSlug}`)
const contactFormId = `enquiry-form-${property?.id ?? 'general'}`
const propertyCta = detail
  ? buildPropertyCtaModel({
      locale,
      settings: siteProfile,
      propertyTitle: detail.title,
      formId: contactFormId,
    })
  : null
---

{property && detail ? (
  <BaseLayout
    site={site}
    title={detail.title}
    description={htmlToMetaDescription(property.description) ?? undefined}
    canonical={new URL(canonicalPath, Astro.url.origin).href}
    breadcrumbs={[
      { name: translateLabel(locale, "Home"), url: localePath(locale, "/") },
      { name: translateLabel(locale, "Properties"), url: localePath(locale, "/properties") },
      { name: detail.title, url: canonicalPath },
    ]}
  >
    <div class="property-detail-page">
      <div class="property-detail-page__main">
        <PropertyDetail detail={detail} />
      </div>

      <aside class="property-detail-page__sidebar">
        <section class="property-detail-page__panel property-detail-page__panel--contact">
          <p class="property-detail-page__eyebrow">{propertyCta?.eyebrow ?? translateLabel(locale, 'Primary action')}</p>
          <h2>{propertyCta?.title ?? translateLabel(locale, 'Arrange a viewing or ask for details')}</h2>
          <p>{propertyCta?.body ?? translateLabel(locale, 'Use the enquiry form to request a viewing, ask for floorplans, or confirm the latest availability with the team.')}</p>

          {propertyCta && (
            <div class="property-detail-page__cta-actions">
              <a
                href={propertyCta.primaryHref}
                class="btn btn-primary property-detail-page__cta-button"
                target={propertyCta.type === 'whatsapp_chat' ? '_blank' : undefined}
                rel={propertyCta.type === 'whatsapp_chat' ? 'noreferrer' : undefined}
              >
                {propertyCta.primaryLabel}
              </a>
              {propertyCta.secondaryLabel && propertyCta.secondaryHref && (
                <a href={propertyCta.secondaryHref} class="btn property-detail-page__cta-secondary">
                  {propertyCta.secondaryLabel}
                </a>
              )}
            </div>
          )}

          <ContactForm
            propertyId={property.id}
            propertyTitle={property.title}
            heading={propertyCta?.formTitle}
            submitLabel={propertyCta?.formSubmitLabel}
            intro={propertyCta?.inlineFormIntro}
            showHeading={false}
          />
        </section>

        <section class="property-detail-page__panel property-detail-page__panel--summary">
          <p class="property-detail-page__eyebrow">{translateLabel(locale, 'Why this listing')}</p>
          <ul class="property-detail-page__notes">
            <li>{translateLabel(locale, 'Strong presentation with a clearer gallery and structured facts at a glance.')}</li>
            <li>{translateLabel(locale, 'Designed to keep key information visible before the enquiry step.')}</li>
            <li>{translateLabel(locale, 'Balanced layout for desktop browsing and mobile follow-up enquiries.')}</li>
          </ul>
        </section>
      </aside>
    </div>

    {similarProperties.length > 0 && (
      <SimilarProperties properties={similarProperties} />
    )}

    {propertyCta?.showsMobileStickyBar && (
      <div class="property-detail-page__mobile-cta">
        <a
          href={propertyCta.primaryHref}
          class="btn btn-primary property-detail-page__mobile-cta-button"
          target={propertyCta.type === 'whatsapp_chat' ? '_blank' : undefined}
          rel={propertyCta.type === 'whatsapp_chat' ? 'noreferrer' : undefined}
        >
          {propertyCta.primaryLabel}
        </a>
      </div>
    )}
  </BaseLayout>
) : (
  <BaseLayout site={site} title={translateLabel(locale, 'Page not found')}>
    <div class="property-detail-page property-detail-page--empty">
      <h1>404</h1>
      <p>{translateLabel(locale, "The property you're looking for doesn't exist.")}</p>
      <p><a href={localePath(locale, '/properties')}>{translateLabel(locale, 'Browse all properties')}</a></p>
    </div>
  </BaseLayout>
)}

<style>
  .property-detail-page {
    width: min(100%, 76rem);
    margin: 0 auto;
    padding: var(--space-section-sm) var(--spacing-page) var(--space-section-lg);
    display: grid;
    grid-template-columns: minmax(0, 1.65fr) minmax(19rem, 0.85fr);
    gap: 1.5rem;
    align-items: start;
  }

  .property-detail-page__sidebar {
    display: grid;
    gap: 1.5rem;
    position: sticky;
    top: calc(var(--nav-height) + 1.5rem);
  }

  .property-detail-page__panel {
    background:
      linear-gradient(180deg, rgba(244, 238, 228, 0.78), rgba(252, 250, 247, 0.94)),
      var(--color-surface);
    border: 1px solid rgba(22, 53, 76, 0.08);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    padding: 1.4rem;
  }

  .property-detail-page__eyebrow {
    margin: 0 0 0.6rem;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .property-detail-page__panel h2 {
    margin: 0 0 0.75rem;
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    line-height: 1;
    color: var(--color-primary);
    letter-spacing: -0.03em;
  }

  .property-detail-page__panel p {
    color: var(--color-text-soft);
    line-height: 1.75;
  }

  .property-detail-page__notes {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--color-text-soft);
    display: grid;
    gap: 0.8rem;
  }

  .property-detail-page__cta-actions {
    display: grid;
    gap: 0.75rem;
    margin: 1.1rem 0 1.2rem;
  }

  .property-detail-page__cta-button,
  .property-detail-page__cta-secondary,
  .property-detail-page__mobile-cta-button {
    width: 100%;
    justify-content: center;
  }

  .property-detail-page__cta-secondary {
    border-radius: var(--radius-md);
    padding: 0.95rem 1.1rem;
    text-decoration: none;
    font-weight: 700;
    color: var(--color-primary);
    border: 1px solid rgba(22, 53, 76, 0.14);
    background: rgba(255, 255, 255, 0.58);
  }

  .property-detail-page__cta-secondary:hover {
    background: rgba(255, 255, 255, 0.9);
  }

  .property-detail-page__mobile-cta {
    display: none;
  }

  .property-detail-page--empty {
    grid-template-columns: 1fr;
    justify-items: center;
    text-align: center;
    min-height: 50vh;
    align-content: center;
  }

  @media (max-width: 960px) {
    .property-detail-page {
      grid-template-columns: 1fr;
    }

    .property-detail-page__sidebar {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .property-detail-page {
      padding-bottom: calc(var(--space-section-lg) + 5.5rem);
    }

    .property-detail-page__mobile-cta {
      display: block;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 40;
      padding: 0.85rem var(--spacing-page) calc(0.85rem + env(safe-area-inset-bottom, 0px));
      background:
        linear-gradient(180deg, rgba(248, 245, 239, 0.74), rgba(248, 245, 239, 0.96)),
        var(--color-surface);
      border-top: 1px solid rgba(22, 53, 76, 0.1);
      backdrop-filter: blur(14px);
    }
  }
</style>
