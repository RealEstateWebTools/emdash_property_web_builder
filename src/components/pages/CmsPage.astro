---
import { getEmDashEntry, getTranslations } from "emdash";
import { PortableText } from "emdash/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TranslationLinks from "../TranslationLinks.astro";
import ContactForm from "../ContactForm.astro";
import { createPwbClient } from "../../lib/pwb/client";
import { fallbackSite } from "../../lib/pwb/fallback-site";
import { readSiteProfileSettingsFromDb } from "../../lib/site-profile";
import { localePath, translateLabel } from "../../lib/locale";

interface Props {
  locale: string
  slug: string
}

const { locale, slug } = Astro.props

const { entry: page, cacheHint } = slug
	? await getEmDashEntry("pages", slug, { locale })
	: { entry: null, cacheHint: undefined };

let site = fallbackSite;
const siteProfile = await readSiteProfileSettingsFromDb(Astro.locals.emdash?.db)
if (page) {
	try {
		site = await createPwbClient(locale).getSiteDetails();
	} catch {
		site = fallbackSite;
	}
	Astro.cache.set(cacheHint);
} else {
	Astro.response.status = 404;
}

const pagePath = localePath(locale, `/pages/${slug}`)
const currentPageHref = new URL(pagePath, Astro.url.origin).href
const alternateLinks = page
	? Array.from(
			new Map(
				[
					{ locale, href: currentPageHref },
					...(await getTranslations('pages', page.data.id)).translations.map((translation) => ({
						locale: translation.locale,
						href: new URL(localePath(translation.locale, `/pages/${translation.slug}`), Astro.url.origin).href,
					})),
				].map((link) => [link.locale, link])
			).values()
		)
	: []
---

{page ? (
	<BaseLayout
		site={site}
		title={page.data.title}
		alternateLinks={alternateLinks}
	>
		<article class:list={['page-article', { 'page-article--contact': slug === 'contact' }]}>
			<header class="page-header">
				<h1 class="page-title" {...page.edit.title}>{page.data.title}</h1>
				<TranslationLinks links={alternateLinks} />
			</header>

			<div class:list={['page-layout', { 'page-layout--contact': slug === 'contact' }]}>
				<div class="page-content">
				<PortableText value={page.data.content} />
				{slug === 'contact' && (
					<section class="contact-form-panel">
						<p class="contact-form-panel__eyebrow">{translateLabel(locale, 'Start the conversation')}</p>
						<ContactForm
							heading={translateLabel(locale, 'Tell us what you need help with')}
							intro={translateLabel(locale, 'Use the form for buying, selling, renting, valuations, or general office questions. The team can route your enquiry to the right next step.')}
							responsePledge={siteProfile.responsePledge}
							pageType="contact"
						/>
					</section>
				)}
				</div>
				{slug === 'contact' && (
					<aside class="contact-details-panel">
						<p class="contact-details-panel__eyebrow">{translateLabel(locale, 'Contact Us')}</p>
						<h2>{siteProfile.brandName}</h2>
						<p class="contact-details-panel__intro">{translateLabel(locale, 'Speak to a real local team for viewings, valuations, landlord questions, and buyer support.')}</p>
						<ul class="contact-details-panel__list">
							<li>
								<span>{translateLabel(locale, 'Address')}</span>
								<strong>{siteProfile.officeAddress}</strong>
							</li>
							<li>
								<span>{translateLabel(locale, 'Phone')}</span>
								<strong><a href={`tel:${siteProfile.officePhone.replace(/[^+\d]/g, '')}`}>{siteProfile.officePhone}</a></strong>
							</li>
							<li>
								<span>{translateLabel(locale, 'Email')}</span>
								<strong><a href={`mailto:${siteProfile.officeEmail}`}>{siteProfile.officeEmail}</a></strong>
							</li>
						</ul>
						<div class="contact-details-panel__actions">
							<a class="btn btn-primary contact-details-panel__action" href={`tel:${siteProfile.officePhone.replace(/[^+\d]/g, '')}`}>
								{translateLabel(locale, 'Call the office')}
							</a>
							<a class="btn contact-details-panel__action contact-details-panel__action--secondary" href={`mailto:${siteProfile.officeEmail}`}>
								{translateLabel(locale, 'Send an email')}
							</a>
						</div>
						<ul class="contact-details-panel__trust-list">
							<li>
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
								{siteProfile.responsePledge}
							</li>
							<li>
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
								{translateLabel(locale, 'Your details are handled with care and never passed to third parties.')}
							</li>
							<li>
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.39 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.06 6.06l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/></svg>
								{translateLabel(locale, 'We can help with viewings, valuations, rentals, and buyer questions.')}
							</li>
						</ul>
					</aside>
				)}
			</div>
		</article>
	</BaseLayout>
) : (
	<BaseLayout site={site} title={translateLabel(locale, 'Page not found')}>
		<article class="page-article">
			<header class="page-header">
				<h1 class="page-title">404</h1>
			</header>

			<div class="page-content">
				<p>{translateLabel(locale, "The page you're looking for doesn't exist.")}</p>
				<p><a href={localePath(locale, '/')}>{translateLabel(locale, 'Go back home')}</a></p>
			</div>
		</article>
	</BaseLayout>
)}

<style>
	.page-article {
		max-width: 1100px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	.page-layout {
		display: grid;
		gap: 2rem;
	}

	.page-layout--contact {
		grid-template-columns: minmax(0, 1.3fr) minmax(18rem, 0.7fr);
		align-items: start;
	}

	.page-header {
		margin-bottom: 2rem;
	}

	.page-title {
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		font-weight: 700;
		line-height: 1.15;
		color: var(--color-text);
	}

	.page-content :global(p) {
		margin-bottom: 1.5em;
		line-height: 1.7;
	}

	.page-content :global(h2) {
		font-size: 1.5rem;
		margin-top: 2em;
		margin-bottom: 0.75em;
	}

	.page-content :global(h3) {
		font-size: 1.25rem;
		margin-top: 1.75em;
		margin-bottom: 0.5em;
	}

	.page-content :global(blockquote) {
		margin: 1.5em 0;
		padding-left: 1.5rem;
		border-left: 3px solid var(--color-border);
		color: var(--color-text-muted);
	}

	.page-content :global(pre) {
		margin: 1.5em 0;
		padding: 1rem;
		background: var(--color-bg-soft);
		border-radius: 4px;
		overflow-x: auto;
		font-family: ui-monospace, monospace;
		font-size: 0.875rem;
	}

	.page-content :global(code) {
		font-family: ui-monospace, monospace;
		font-size: 0.9em;
		background: var(--color-bg-soft);
		padding: 0.15em 0.3em;
		border-radius: 4px;
	}

	.page-content :global(pre code) {
		background: none;
		padding: 0;
	}

	.page-content :global(ul),
	.page-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: 1.25rem;
	}

	.page-content :global(li) {
		margin-bottom: 0.5em;
	}

	.contact-details-panel {
		background:
			linear-gradient(180deg, rgba(244, 238, 228, 0.82), rgba(252, 250, 247, 0.96)),
			var(--color-surface);
		border: 1px solid rgba(22, 53, 76, 0.08);
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-md);
		padding: 1.5rem;
		position: sticky;
		top: calc(var(--nav-height) + 1.5rem);
	}

	.contact-details-panel__eyebrow {
		margin: 0 0 0.7rem;
		font-size: var(--text-xs);
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.contact-details-panel h2 {
		margin: 0 0 1rem;
		font-family: var(--font-serif);
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		line-height: 1;
		color: var(--color-primary);
		letter-spacing: -0.03em;
	}

	.contact-details-panel__intro {
		margin: 0 0 1.1rem;
		color: var(--color-text-soft);
		line-height: 1.75;
	}

	.contact-details-panel__list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 1rem;
	}

	.contact-details-panel__list li {
		display: grid;
		gap: 0.25rem;
	}

	.contact-details-panel__list span {
		font-size: var(--text-xs);
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-text-soft);
	}

	.contact-details-panel__list strong,
	.contact-details-panel__list a {
		color: var(--color-primary);
		font-size: var(--text-base);
		text-decoration: none;
	}

	.contact-details-panel__list a:hover {
		color: var(--color-accent);
	}

	.contact-details-panel__actions {
		display: grid;
		gap: 0.75rem;
		margin-top: 1.25rem;
	}

	.contact-details-panel__action {
		width: 100%;
		justify-content: center;
	}

	.contact-details-panel__action--secondary {
		border-radius: var(--radius-md);
		padding: 0.95rem 1.1rem;
		text-decoration: none;
		font-weight: 700;
		color: var(--color-primary);
		border: 1px solid rgba(22, 53, 76, 0.14);
		background: rgba(255, 255, 255, 0.58);
	}

	.contact-details-panel__action--secondary:hover {
		background: rgba(255, 255, 255, 0.9);
	}

	.contact-details-panel__trust-list {
		list-style: none;
		margin: 1.25rem 0 0;
		padding: 0;
		color: var(--color-text-soft);
		display: grid;
		gap: 0.7rem;
		font-size: var(--text-xs);
		line-height: 1.5;
	}

	.contact-details-panel__trust-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.45rem;
	}

	.contact-details-panel__trust-list li svg {
		flex-shrink: 0;
		margin-top: 0.1em;
		color: var(--color-accent);
		opacity: 0.8;
	}

	.contact-form-panel {
		margin-top: 2rem;
		padding: 1.5rem;
		border-radius: var(--radius-xl);
		border: 1px solid rgba(22, 53, 76, 0.08);
		background:
			linear-gradient(180deg, rgba(244, 238, 228, 0.72), rgba(252, 250, 247, 0.94)),
			var(--color-surface);
		box-shadow: var(--shadow-md);
	}

	.contact-form-panel__eyebrow {
		margin: 0 0 0.7rem;
		font-size: var(--text-xs);
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	@media (max-width: 860px) {
		.page-layout--contact {
			grid-template-columns: 1fr;
		}

		.contact-details-panel {
			position: static;
		}
	}
</style>
