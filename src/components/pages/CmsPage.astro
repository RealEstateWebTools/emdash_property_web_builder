---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createPwbClient } from "../../lib/pwb/client";
import { fallbackSite } from "../../lib/pwb/fallback-site";
import { localePath, translateLabel } from "../../lib/locale";

interface Props {
  locale: string
  slug: string
}

const { locale, slug } = Astro.props

const { entry: page, cacheHint } = slug
	? await getEmDashEntry("pages", slug, { locale })
	: { entry: null, cacheHint: undefined };

let site = fallbackSite;
if (page) {
	try {
		site = await createPwbClient(locale).getSiteDetails();
	} catch {
		site = fallbackSite;
	}
	Astro.cache.set(cacheHint);
} else {
	Astro.response.status = 404;
}
---

{page ? (
	<BaseLayout
		site={site}
		title={page.data.title}
	>
		<article class="page-article">
			<header class="page-header">
				<h1 class="page-title" {...page.edit.title}>{page.data.title}</h1>
			</header>

			<div class="page-content">
				<PortableText value={page.data.content} />
			</div>
		</article>
	</BaseLayout>
) : (
	<BaseLayout site={site} title={translateLabel(locale, 'Page not found')}>
		<article class="page-article">
			<header class="page-header">
				<h1 class="page-title">404</h1>
			</header>

			<div class="page-content">
				<p>{translateLabel(locale, "The page you're looking for doesn't exist.")}</p>
				<p><a href={localePath(locale, '/')}>{translateLabel(locale, 'Go back home')}</a></p>
			</div>
		</article>
	</BaseLayout>
)}

<style>
	.page-article {
		max-width: 800px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	.page-header {
		margin-bottom: 2rem;
	}

	.page-title {
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		font-weight: 700;
		line-height: 1.15;
		color: var(--color-text);
	}

	.page-content :global(p) {
		margin-bottom: 1.5em;
		line-height: 1.7;
	}

	.page-content :global(h2) {
		font-size: 1.5rem;
		margin-top: 2em;
		margin-bottom: 0.75em;
	}

	.page-content :global(h3) {
		font-size: 1.25rem;
		margin-top: 1.75em;
		margin-bottom: 0.5em;
	}

	.page-content :global(blockquote) {
		margin: 1.5em 0;
		padding-left: 1.5rem;
		border-left: 3px solid var(--color-border);
		color: var(--color-text-muted);
	}

	.page-content :global(pre) {
		margin: 1.5em 0;
		padding: 1rem;
		background: var(--color-bg-soft);
		border-radius: 4px;
		overflow-x: auto;
		font-family: ui-monospace, monospace;
		font-size: 0.875rem;
	}

	.page-content :global(code) {
		font-family: ui-monospace, monospace;
		font-size: 0.9em;
		background: var(--color-bg-soft);
		padding: 0.15em 0.3em;
		border-radius: 4px;
	}

	.page-content :global(pre code) {
		background: none;
		padding: 0;
	}

	.page-content :global(ul),
	.page-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: 1.25rem;
	}

	.page-content :global(li) {
		margin-bottom: 0.5em;
	}
</style>
