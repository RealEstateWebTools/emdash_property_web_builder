---
import { createPwbClient } from '../../lib/pwb/client'
import { fallbackSite } from '../../lib/pwb/fallback-site'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { localePath, translateLabel } from '../../lib/locale'
import { isPwbNotFoundError, logPwbUnexpectedError } from '../../lib/pwb/errors'
import { shouldQueryPwbPageSlug } from '../../lib/pwb/page-slug'

interface Props {
  locale: string
  slug?: string | string[]
}

const { locale, slug } = Astro.props
const pageSlug = Array.isArray(slug) ? slug.join('/') : (slug ?? 'home')

let page = null
let site = fallbackSite
let loadState: 'ok' | 'not_found' | 'unavailable' = 'ok'

if (!shouldQueryPwbPageSlug(pageSlug)) {
  loadState = 'not_found'
  Astro.response.status = 404
} else {
  try {
    const client = createPwbClient(locale)
    ;[page, site] = await Promise.all([
      client.getPageBySlug(pageSlug),
      client.getSiteDetails(),
    ])
  } catch (err) {
    if (isPwbNotFoundError(err)) {
      loadState = 'not_found'
      Astro.response.status = 404
    } else {
      loadState = 'unavailable'
      Astro.response.status = 502
      logPwbUnexpectedError(`page slug=${pageSlug}`, err)
    }
  }
}
---

{loadState === 'unavailable' ? (
  <BaseLayout site={site} title={translateLabel(locale, 'Page temporarily unavailable')}>
    <article class="cms-page">
      <h1>{translateLabel(locale, 'Page temporarily unavailable')}</h1>
      <section class="page-content-block">
        <p>{translateLabel(locale, 'Please try again shortly.')}</p>
        <p><a href={localePath(locale, '/')}>{translateLabel(locale, 'Go back home')}</a></p>
      </section>
    </article>
  </BaseLayout>
) : loadState === 'not_found' || !page ? (
  <BaseLayout site={site} title={translateLabel(locale, 'Page not found')}>
    <article class="cms-page">
      <h1>404</h1>
      <section class="page-content-block">
        <p>{translateLabel(locale, "The page you're looking for doesn't exist.")}</p>
        <p><a href={localePath(locale, '/')}>{translateLabel(locale, 'Go back home')}</a></p>
      </section>
    </article>
  </BaseLayout>
) : (
  <BaseLayout
    site={site}
    title={page.title}
    description={page.meta_description ?? undefined}
  >
    <article class="cms-page">
      <h1>{page.title}</h1>
      {page.page_contents
        .filter((pc) => pc.visible && !pc.is_rails_part)
        .sort((a, b) => a.sort_order - b.sort_order)
        .map((pc) => (
          pc.rendered_html && (
            <section
              class="page-content-block"
              data-part-key={pc.page_part_key}
              set:html={pc.rendered_html}
            />
          )
        ))
      }
    </article>
  </BaseLayout>
)}

<style>
  .cms-page { max-width: 800px; margin: 0 auto; padding: 2rem var(--spacing-page); }
  .cms-page h1 { font-size: var(--text-3xl); margin-bottom: 2rem; }
  .page-content-block { margin-bottom: 2rem; }
</style>
