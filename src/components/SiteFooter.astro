---
import { getMenu } from 'emdash'
import { WidgetArea } from 'emdash/ui'
import { DEFAULT_LOCALE, localePath, translateBrand, translateLabel } from '../lib/locale'

interface Props {
  siteTitle: string
}

const { siteTitle } = Astro.props
const menu = await getMenu('primary')
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const localizedSiteTitle = translateBrand(currentLocale, siteTitle)
const menuItems = menu?.items ?? []

const defaultNavItems: Array<{ url: string; label: string; target?: string }> = [
  { url: '/', label: translateLabel(currentLocale, 'Home') },
  { url: '/properties', label: translateLabel(currentLocale, 'Properties') },
  { url: '/posts', label: translateLabel(currentLocale, 'Posts') },
]

const hasMenuUrl = (url: string) =>
  menuItems.some((item) => item.url === url || item.url.startsWith(`${url}/`))

const combinedFooterItems = [
  ...defaultNavItems.filter((item) => !hasMenuUrl(item.url)),
  ...menuItems.map((item) => ({
    url: item.url,
    label: translateLabel(currentLocale, item.label),
    target: item.target,
  })),
]
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={localePath(currentLocale, '/')} class="footer-logo">{localizedSiteTitle}</a>
      </div>
      <div class="footer-nav">
        <h4 class="footer-heading">{translateLabel(currentLocale, 'Navigate')}</h4>
        <ul class="footer-links">
          {combinedFooterItems.map(item => (
            <li>
              <a
				href={localePath(currentLocale, item.url)}
                target={item.target}
                rel={item.target === '_blank' ? 'noopener noreferrer' : undefined}
              >
				{item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div class="footer-widgets-section">
        <WidgetArea name="footer" />
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-copyright">&copy; {new Date().getFullYear()} {localizedSiteTitle}</p>
      <a
        href="https://github.com/RealEstateWebTools/emdash_property_web_builder"
        class="footer-github"
        target="_blank"
        rel="noopener noreferrer"
      >View on GitHub</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    margin-top: 8rem;
    position: relative;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 1.5rem 3rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
    margin-bottom: 5rem;
  }

  .footer-logo {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-primary);
    text-decoration: none;
    font-family: var(--font-serif);
    letter-spacing: -0.02em;
  }

  .footer-heading {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: 1.75rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.875rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-base);
    transition: all 0.2s;
    font-weight: 500;
  }

  .footer-links a:hover {
    color: var(--color-accent);
    padding-left: 4px;
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copyright {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    font-weight: 500;
  }

  .footer-github {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-github:hover {
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    .footer-brand {
      grid-column: span 2;
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .footer-brand {
      grid-column: span 1;
    }
    .footer-inner {
      padding-top: 4rem;
    }
  }
</style>
