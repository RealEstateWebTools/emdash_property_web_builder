---
import type { MapMarker } from '../lib/pwb/types'

interface Props {
  markers: MapMarker[]
}

const { markers } = Astro.props
const markersJson = JSON.stringify(markers)
---

{markers.length > 0 && (
  <>
    <div id="map" class="map-view" aria-label="Property locations map" data-markers={markersJson}></div>

    <script type="module">
      import { buildMarkerPopupHtml } from '../lib/map/popup'

      const mapEl = document.getElementById('map')
      if (mapEl) {
        const markers = JSON.parse(mapEl.getAttribute('data-markers') ?? '[]')
        if (!Array.isArray(markers) || markers.length === 0) {
          mapEl.remove()
        } else {
          await import('leaflet/dist/leaflet.css')
          const L = await import('leaflet')

          const map = L.map(mapEl)
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
          }).addTo(map)

          const bounds = []
          markers.forEach((m) => {
            const popup = buildMarkerPopupHtml({
              url: String(m.url ?? '#'),
              title: String(m.title ?? ''),
              price: m.price == null ? null : String(m.price),
            })
            L.marker([Number(m.lat), Number(m.lng)]).bindPopup(popup).addTo(map)
            bounds.push([Number(m.lat), Number(m.lng)])
          })

          map.fitBounds(bounds, { padding: [40, 40] })
        }
      }
    </script>
  </>
)}

<style>
  .map-view {
    height: 400px;
    width: 100%;
    border-radius: var(--radius-md);
    margin: 2rem 0;
  }
</style>
