---
import { DEFAULT_LOCALE, translateLabel } from '../lib/locale'

interface Props {
  propertyId?: number
  propertyTitle?: string
  heading?: string
  submitLabel?: string
  intro?: string
  showHeading?: boolean
  responsePledge?: string
}

const { propertyId, propertyTitle, heading: headingOverride, submitLabel, intro, showHeading = true, responsePledge } = Astro.props
const formId = `enquiry-form-${propertyId ?? 'general'}`
const nameId = `${formId}-name`
const emailId = `${formId}-email`
const phoneId = `${formId}-phone`
const messageId = `${formId}-message`
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const heading = headingOverride ?? (propertyTitle
  ? `${translateLabel(currentLocale, 'Enquire about')} ${propertyTitle}`
  : translateLabel(currentLocale, 'Contact Us'))
const submitText = submitLabel ?? translateLabel(currentLocale, 'Send Enquiry')
---

<form
  id={formId}
  class="contact-form"
  data-property-id={propertyId}
  data-success-message={translateLabel(currentLocale, 'Your enquiry has been sent!')}
  data-error-message={translateLabel(currentLocale, 'Something went wrong. Please try again.')}
  data-network-error-message={translateLabel(currentLocale, 'Network error. Please try again.')}
  novalidate
>
  {showHeading && <h2>{heading}</h2>}
  {intro && <p class="contact-form__intro">{intro}</p>}

  <div class="form-group">
    <label for={nameId}>{translateLabel(currentLocale, 'Name *')}</label>
    <input type="text" id={nameId} name="name" required autocomplete="name" />
    <span class="field-error" data-field="name" aria-live="polite"></span>
  </div>

  <div class="form-group">
    <label for={emailId}>{translateLabel(currentLocale, 'Email *')}</label>
    <input type="email" id={emailId} name="email" required autocomplete="email" />
    <span class="field-error" data-field="email" aria-live="polite"></span>
  </div>

  <div class="form-group">
    <label for={phoneId}>{translateLabel(currentLocale, 'Phone (optional)')}</label>
    <input type="tel" id={phoneId} name="phone" autocomplete="tel" />
  </div>

  <div class="form-group">
    <label for={messageId}>{translateLabel(currentLocale, 'Message *')}</label>
    <textarea id={messageId} name="message" rows="5" required></textarea>
    <span class="field-error" data-field="message" aria-live="polite"></span>
  </div>

  <div class="form-status" aria-live="polite"></div>

  <button type="submit" class="btn btn-primary contact-form__submit">
    <span class="btn-text">{submitText}</span>
    <span class="btn-loading" hidden>{translateLabel(currentLocale, 'Sending...')}</span>
  </button>

  {responsePledge && (
    <p class="contact-form__pledge">
      <svg class="contact-form__pledge-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      {responsePledge}
    </p>
  )}
</form>

<script>
  import { validateEnquiry } from '../lib/pwb/enquiry-validator'

  document.querySelectorAll<HTMLFormElement>('.contact-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault()

      const data = Object.fromEntries(new FormData(form))
      const validation = validateEnquiry({
        name: String(data.name ?? ''),
        email: String(data.email ?? ''),
        message: String(data.message ?? ''),
      })

      form.querySelectorAll('.field-error').forEach((el) => (el.textContent = ''))
      form.querySelector('.form-status')!.textContent = ''

      if (!validation.valid) {
        Object.entries(validation.errors).forEach(([field, msg]) => {
          const el = form.querySelector<HTMLElement>(`[data-field="${field}"]`)
          if (el) el.textContent = msg ?? ''
        })
        return
      }

      const btnText = form.querySelector('.btn-text')!
      const btnLoading = form.querySelector<HTMLElement>('.btn-loading')!
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type=submit]')!
      btnText.setAttribute('hidden', '')
      btnLoading.removeAttribute('hidden')
      submitBtn.disabled = true

      const propertyId = form.dataset.propertyId
      const successMessage = form.dataset.successMessage ?? 'Your enquiry has been sent!'
      const errorMessage = form.dataset.errorMessage ?? 'Something went wrong. Please try again.'
      const networkErrorMessage = form.dataset.networkErrorMessage ?? 'Network error. Please try again.'

      try {
        const res = await fetch('/api/enquiries', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({
            name: data.name,
            email: data.email,
            phone: data.phone || undefined,
            message: data.message,
            property_id: propertyId ?? undefined,
          }),
        })

        const result = await res.json() as {
          success: boolean
          message?: string
          errors?: string[]
          fieldErrors?: Record<string, string>
        }
        const status = form.querySelector('.form-status')!

        if (result.success) {
          form.reset()
          status.textContent = result.message ?? successMessage
          status.className = 'form-status success'
        } else {
          if (result.fieldErrors) {
            Object.entries(result.fieldErrors).forEach(([field, msg]) => {
              const el = form.querySelector<HTMLElement>(`[data-field="${field}"]`)
              if (el) el.textContent = msg
            })
          }
          status.textContent = result.errors?.join(', ') ?? result.message ?? errorMessage
          status.className = 'form-status error'
        }
      } catch {
        form.querySelector('.form-status')!.textContent = networkErrorMessage
      } finally {
        btnText.removeAttribute('hidden')
        btnLoading.setAttribute('hidden', '')
        submitBtn.disabled = false
      }
    })
  })
</script>

<style>
  .contact-form {
    margin: 0;
    padding: 0;
    max-width: none;
  }

  .contact-form h2 {
    margin: 0 0 1.25rem;
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    line-height: 1;
    color: var(--color-primary);
    letter-spacing: -0.03em;
  }

  .contact-form__intro {
    margin: 0 0 1.1rem;
    color: var(--color-text-soft);
    line-height: 1.75;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.4rem;
    color: var(--color-text-soft);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 0.9rem 1rem;
    border: 1px solid rgba(22, 53, 76, 0.12);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    background: rgba(255, 255, 255, 0.88);
    color: var(--color-text);
  }

  .contact-form__submit {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .contact-form__pledge {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    margin: 0.75rem 0 0;
    font-size: var(--text-xs);
    color: var(--color-text-soft);
    line-height: 1.5;
  }

  .contact-form__pledge-icon {
    flex-shrink: 0;
    margin-top: 0.05em;
    color: var(--color-accent);
    opacity: 0.8;
  }
</style>
