---
import type { SearchConfig, SearchFacets, SearchParams } from '../lib/pwb/types'

interface Props {
  config: SearchConfig
  facets: SearchFacets
  currentParams: SearchParams
  mode: 'sale' | 'rental'
}

const { config, currentParams, mode } = Astro.props
---

<section class="search-bar">
  <form method="get" action="/properties">
    <input type="hidden" name="mode" value={mode} />

    <select name="type" aria-label="Property type">
      <option value="">All types</option>
      {config.property_types.map((pt) => (
        <option value={pt.key} selected={currentParams.property_type === pt.key}>
          {pt.label} ({pt.count})
        </option>
      ))}
    </select>

    <select name="bedrooms" aria-label="Bedrooms">
      <option value="">Any bedrooms</option>
      {config.bedrooms.filter(b => b > 0).map((b) => (
        <option value={String(b)} selected={currentParams.bedrooms_from === String(b)}>
          {b}+ bed
        </option>
      ))}
    </select>

    <select name="price_from" aria-label="Min price">
      <option value="">Min price</option>
      {(mode === 'rental' ? config.price_options.rent.from : config.price_options.sale.from)
        .filter(p => p > 0)
        .map((p) => (
          <option value={String(p)}>{p.toLocaleString()}</option>
        ))
      }
    </select>

    <select name="price_to" aria-label="Max price">
      <option value="">Max price</option>
      {(mode === 'rental' ? config.price_options.rent.to : config.price_options.sale.to)
        .map((p) => (
          <option value={String(p)}>{p.toLocaleString()}</option>
        ))
      }
    </select>

    <select name="sort" aria-label="Sort by">
      {config.sort_options.map((s) => (
        <option value={s.value} selected={currentParams.sort_by === s.value}>
          {s.label}
        </option>
      ))}
    </select>

    <button type="submit" class="btn btn-primary">Search</button>
  </form>
</section>
