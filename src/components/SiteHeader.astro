---
import { getMenu } from 'emdash'
import type { SiteDetails } from '../lib/pwb/types'
import { fallbackSite } from '../lib/pwb/fallback-site'
import type { SiteProfileSettings } from '../lib/site-profile'
import { ALL_LOCALES, DEFAULT_LOCALE, localeLabel, localePath, translateBrand, translateLabel } from '../lib/locale'

interface Props {
  site: SiteDetails
  siteProfile: SiteProfileSettings
}

const { site, siteProfile } = Astro.props
const primaryMenu = await getMenu('primary')
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const menuItems = primaryMenu?.items ?? []
const fallbackBrand = translateBrand(
  currentLocale,
  fallbackSite.company_display_name ?? fallbackSite.title,
)
const localizedBrand = translateBrand(currentLocale, site.company_display_name ?? site.title)
const displayBrand = localizedBrand && localizedBrand !== 'Home' ? localizedBrand : fallbackBrand

const defaultNavItems: Array<{ url: string; label: string; target?: string }> = [
  { url: '/properties', label: translateLabel(currentLocale, 'Properties') },
  { url: '/posts', label: translateLabel(currentLocale, 'Posts') },
]

const normalizeUrl = (url: string) => {
  const normalized = url.trim() || '/'
  if (normalized === '/') return normalized
  return normalized.endsWith('/') ? normalized.slice(0, -1) : normalized
}

const hasMenuUrl = (url: string) => {
  const candidate = normalizeUrl(url)
  return menuItems.some((item) => {
    const target = normalizeUrl(item.url)
    return target === candidate || target.startsWith(`${candidate}/`)
  })
}

const combinedNavItems = [
  ...defaultNavItems.filter((item) => !hasMenuUrl(item.url)),
  ...menuItems.map((item) => ({
    url: item.url,
    label: translateLabel(currentLocale, item.label),
    target: item.target,
  })),
].filter((item, index, items) => (
  items.findIndex((candidate) => normalizeUrl(candidate.url) === normalizeUrl(item.url)) === index
)).filter((item) => item.label !== translateLabel(currentLocale, 'Home'))
---

<header class="site-header">
  <div class="site-header__topbar">
    <div class="site-header__topbar-inner">
      <p>{siteProfile.tagline}</p>
      <div class="site-header__locales" aria-label="Language switcher">
        {ALL_LOCALES.map((locale) => (
          <a
            href={localePath(locale, '/')}
            class:list={['site-header__locale', { 'site-header__locale--active': locale === currentLocale }]}
            aria-current={locale === currentLocale ? 'page' : undefined}
          >
            {localeLabel(locale)}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="site-header__main">
    <div class="site-header__inner">
      <a href={localePath(currentLocale, '/')} class="site-header__logo">
        {site.logo_url
          ? <img src={site.logo_url} alt={displayBrand} height="42" class="logo-image" />
          : <span class="site-header__title">{displayBrand}</span>
        }
      </a>

      <button
        class="menu-toggle"
        aria-label="Toggle menu"
        aria-controls="nav-content"
        aria-expanded="false"
        id="menu-toggle"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="menu-icon"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="close-icon"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

      <div class="site-header__actions" id="nav-content">
        <nav class="site-header__nav" aria-label="Main navigation">
          {combinedNavItems.map(item => (
            <a href={localePath(currentLocale, item.url)} target={item.target}>{item.label}</a>
          ))}
        </nav>

        <a href={localePath(currentLocale, '/contact')} class="site-header__cta">
          {translateLabel(currentLocale, 'Contact Us')}
        </a>
      </div>

      <button
        type="button"
        class="site-header__scrim"
        aria-label="Close menu"
        aria-hidden="true"
        tabindex="-1"
      ></button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('nav-content');
  const scrim = document.querySelector('.site-header__scrim');
  const body = document.body;
  const navLinks = nav?.querySelectorAll('a');

  const closeMenu = () => {
    toggle?.setAttribute('aria-expanded', 'false');
    nav?.classList.remove('is-open');
    toggle?.classList.remove('is-active');
    body.classList.remove('menu-open');
  };

  const openMenu = () => {
    toggle?.setAttribute('aria-expanded', 'true');
    nav?.classList.add('is-open');
    toggle?.classList.add('is-active');
    body.classList.add('menu-open');
  };

  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    if (isExpanded) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  scrim?.addEventListener('click', closeMenu);

  navLinks?.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenu();
    }
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) {
      closeMenu();
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .site-header__topbar {
    background: var(--color-primary);
    color: var(--color-on-dark);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .site-header__topbar-inner,
  .site-header__inner {
    width: min(100%, 76rem);
    margin: 0 auto;
    padding-left: var(--spacing-page);
    padding-right: var(--spacing-page);
  }

  .site-header__topbar-inner {
    min-height: 2.65rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-header__topbar-inner p {
    margin: 0;
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(246, 242, 235, 0.82);
  }

  .site-header__main {
    background: rgba(255, 252, 247, 0.9);
    backdrop-filter: blur(18px);
    border-bottom: var(--header-border);
  }

  .site-header__inner {
    min-height: calc(var(--nav-height) - 2.65rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .site-header__logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    z-index: 1001;
    color: var(--color-primary);
  }

  .site-header__title {
    font-size: clamp(2rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--color-primary);
    font-family: var(--font-serif);
    letter-spacing: -0.04em;
    line-height: 0.95;
  }

  .logo-image {
    height: 42px;
    width: auto;
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--nav-actions-gap);
  }

  .site-header__scrim {
    display: none;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--nav-gap);
  }

  .site-header__nav a {
    text-decoration: none;
    color: var(--color-nav-link);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: color var(--transition-base);
    position: relative;
  }

  .site-header__nav a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.4rem;
    width: 100%;
    height: 1px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-base);
  }

  .site-header__nav a:hover {
    color: var(--color-accent);
  }

  .site-header__nav a:hover::after {
    transform: scaleX(1);
  }

  .site-header__locales {
    display: flex;
    gap: 0.35rem;
  }

  .site-header__locale {
    text-decoration: none;
    font-size: 0.68rem;
    color: rgba(246, 242, 235, 0.72);
    padding: 0.3rem 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    font-weight: 700;
    letter-spacing: 0.08em;
    transition: all var(--transition-base);
  }

  .site-header__locale:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: var(--color-on-dark);
  }

  .site-header__locale--active {
    color: var(--color-primary);
    background: var(--color-surface-strong);
    border-color: var(--color-surface-strong);
  }

  .site-header__cta {
    text-decoration: none;
    color: var(--color-on-accent);
    background: var(--color-accent);
    border-radius: 999px;
    padding: 0.8rem 1.2rem;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: background var(--transition-base), transform var(--transition-base);
  }

  .site-header__cta:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .menu-toggle {
    display: none;
    background: transparent;
    border: none;
    color: var(--color-primary);
    cursor: pointer;
    padding: 0.5rem;
    z-index: 1001;
    transition: color var(--transition-base);
  }

  :global(body.menu-open) {
    overflow: hidden;
  }

  .menu-toggle .close-icon {
    display: none;
  }

  .menu-toggle.is-active .menu-icon {
    display: none;
  }

  .menu-toggle.is-active .close-icon {
    display: block;
  }

  @media (max-width: 900px) {
    .site-header__topbar-inner p {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .menu-toggle {
      display: block;
    }

    .site-header__actions {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(100vw, 24rem);
      height: 100vh;
      background: rgba(255, 250, 243, 0.98);
      backdrop-filter: blur(18px);
      flex-direction: column;
      justify-content: center;
      padding: 2rem;
      transform: translateX(100%);
      opacity: 0;
      visibility: hidden;
      transition:
        transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        opacity 0.24s ease,
        visibility 0.24s ease;
      z-index: 1000;
      gap: 2rem;
      border-left: 1px solid rgba(22, 53, 76, 0.12);
      box-shadow: -24px 0 48px rgba(9, 26, 39, 0.14);
    }

    .site-header__actions.is-open {
      transform: translateX(0);
      opacity: 1;
      visibility: visible;
    }

    .site-header__nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .site-header__nav a {
      font-size: var(--text-sm);
      color: var(--color-primary);
      transform: translateX(1rem);
      opacity: 0;
      transition:
        transform 0.32s ease,
        opacity 0.24s ease,
        color var(--transition-base);
    }

    .site-header__actions.is-open .site-header__nav a,
    .site-header__actions.is-open .site-header__cta {
      transform: translateX(0);
      opacity: 1;
    }

    .site-header__cta {
      width: 100%;
      text-align: center;
      justify-content: center;
      transform: translateX(1rem);
      opacity: 0;
      transition:
        transform 0.32s ease 0.06s,
        opacity 0.24s ease 0.06s,
        background var(--transition-base);
    }

    .site-header__topbar-inner {
      justify-content: flex-end;
    }

    .site-header__scrim {
      display: block;
      position: fixed;
      inset: 0;
      border: 0;
      padding: 0;
      background: rgba(9, 26, 39, 0.28);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.24s ease, visibility 0.24s ease;
      z-index: 999;
      backdrop-filter: blur(2px);
    }

    :global(body.menu-open) .site-header__scrim {
      opacity: 1;
      visibility: visible;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__nav a,
    .site-header__cta,
    .site-header__actions,
    .site-header__scrim {
      transition: none !important;
      transform: none !important;
    }
  }
</style>
