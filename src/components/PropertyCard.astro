---
import type { PropertyCardData } from '../lib/pwb/formatters'
import { DEFAULT_LOCALE, localePath } from '../lib/locale'

interface Props {
  card: PropertyCardData
}

const { card } = Astro.props
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const href = localePath(currentLocale, card.href)
---

<article class="property-card">
  <a href={href} class="property-card__link" aria-label={card.title}>
    {card.image
      ? <img class="property-card__image" src={card.image} alt={card.title} loading="lazy" />
      : <div class="property-card__image property-card__image--placeholder" aria-hidden="true" />
    }
  </a>

  {card.featured && (
    <span class="property-card__badge">Featured</span>
  )}

  <div class="property-card__body">
    {card.price && <p class="property-card__price">{card.price}</p>}
    <h2 class="property-card__title">
      <a href={href}>{card.title}</a>
    </h2>
    <ul class="property-card__meta">
      {card.bedrooms != null && <li>{card.bedrooms} bed</li>}
      {card.bathrooms != null && <li>{card.bathrooms} bath</li>}
      {card.area && <li>{card.area}</li>}
    </ul>
  </div>
</article>
