---
import type { PropertyCardData } from '../lib/pwb/formatters'
import { DEFAULT_LOCALE, localePath, translateLabel } from '../lib/locale'

interface Props {
  card: PropertyCardData
}

const { card } = Astro.props
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const href = localePath(currentLocale, card.href)
const statusLabel = card.forSale
  ? translateLabel(currentLocale, 'For sale')
  : card.forRent
    ? translateLabel(currentLocale, 'For rent')
    : null
---

<article class="property-card">
  <a href={href} class="property-card__link" aria-label={card.title}>
    <div class="property-card__image-container">
      {card.image
        ? <img class="property-card__image" src={card.image} alt={card.title} loading="lazy" />
        : <div class="property-card__image property-card__image--placeholder" aria-hidden="true" />
      }

      <div class="property-card__badges">
        {statusLabel && <span class="property-card__status">{statusLabel}</span>}
        {card.featured && (
          <span class="property-card__badge">{translateLabel(currentLocale, 'Featured')}</span>
        )}
      </div>
    </div>
  </a>

  <div class="property-card__body">
    <div class="property-card__header">
      {card.price && <p class="property-card__price">{card.price}</p>}
      <h2 class="property-card__title">
        <a href={href}>{card.title}</a>
      </h2>
    </div>

    <ul class="property-card__meta">
      {card.bedrooms != null && (
        <li title={translateLabel(currentLocale, 'Bedrooms')}>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>
          <span>{card.bedrooms}</span>
        </li>
      )}
      {card.bathrooms != null && (
        <li title={translateLabel(currentLocale, 'Bathrooms')}>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-1C4.3 2.4 3 3.5 3 5c0 .6.3 1.2.7 1.6l2.5 2.4"/><path d="M3 22h18c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2H3c-1.1 0-2 .9-2 2v11c0 1.1.9 2 2 2z"/><path d="M7 8.5V13"/><path d="M17 8.5V13"/><path d="M3 13h18"/></svg>
          <span>{card.bathrooms}</span>
        </li>
      )}
      {card.area && (
        <li title={translateLabel(currentLocale, 'Area')}>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          <span>{card.area}</span>
        </li>
      )}
    </ul>
  </div>
</article>

<style>
  .property-card {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(22, 53, 76, 0.08);
    background: var(--color-surface-strong);
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .property-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
    border-color: rgba(22, 53, 76, 0.18);
  }

  .property-card__link {
    display: block;
  }

  .property-card__image-container {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-soft);
  }

  .property-card__image {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    width: 100%;
    height: 100%;
    transition: transform 0.6s ease;
  }

  .property-card:hover .property-card__image {
    transform: scale(1.04);
  }

  .property-card__image--placeholder {
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, rgba(22, 53, 76, 0.08), rgba(185, 138, 78, 0.14));
  }

  .property-card__badges {
    position: absolute;
    inset: 1rem 1rem auto 1rem;
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 0.5rem;
  }

  .property-card__status,
  .property-card__badge {
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(8px);
  }

  .property-card__status {
    background: rgba(9, 26, 39, 0.72);
    color: var(--color-on-dark);
  }

  .property-card__badge {
    background: rgba(185, 138, 78, 0.9);
    color: var(--color-primary);
  }

  .property-card__body {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 12rem;
    padding: 1.4rem 1.4rem 1.6rem;
  }

  .property-card__price {
    font-size: clamp(1.3rem, 2vw, 1.65rem);
    font-weight: 800;
    color: var(--color-primary);
  }

  .property-card__title {
    margin-top: 0.45rem;
    line-height: 1.08;
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 2vw, 2rem);
    letter-spacing: -0.03em;
  }

  .property-card__title a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .property-card__title a:hover {
    color: var(--color-accent);
  }

  .property-card__meta {
    list-style: none;
    padding: 1rem 0 0;
    margin-top: 1.25rem;
    border-top: 1px solid rgba(22, 53, 76, 0.08);
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-6);
  }

  .property-card__meta li {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    color: var(--color-text-soft);
    font-weight: 600;
  }

  .property-card__meta .icon {
    color: var(--color-accent);
    opacity: 0.9;
  }
</style>
