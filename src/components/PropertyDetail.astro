---
import type { PropertyDetailData } from '../lib/pwb/detail-formatter'
import PropertyGallery from './PropertyGallery.astro'
import PropertyFacts from './PropertyFacts.astro'

interface Props {
  detail: PropertyDetailData
}

const { detail } = Astro.props
---

<article class="property-detail">
  <PropertyGallery detail={detail} />
  <PropertyFacts detail={detail} />
</article>

<style>
  .property-detail {
    display: grid;
    gap: 1.5rem;
  }

  .property-detail :global(.property-detail__hero),
  .property-detail :global(.property-detail__content) {
    background: var(--color-surface-strong);
    border: 1px solid rgba(22, 53, 76, 0.08);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    animation: property-panel-enter 460ms ease both;
  }

  .property-detail :global(.property-detail__content) {
    animation-delay: 70ms;
  }

  @keyframes property-panel-enter {
    from {
      opacity: 0;
      transform: translateY(1rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .property-detail :global(.property-detail__hero),
    .property-detail :global(.property-detail__content) {
      animation: none !important;
    }
  }
</style>
