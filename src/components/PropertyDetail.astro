---
import type { PropertyDetailData } from '../lib/pwb/detail-formatter'
import { DEFAULT_LOCALE, translateLabel } from '../lib/locale'

interface Props {
  detail: PropertyDetailData
}

const { detail } = Astro.props
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const statusLabel = detail.forSale
  ? translateLabel(currentLocale, 'For sale')
  : detail.forRent
    ? translateLabel(currentLocale, 'For rent')
    : translateLabel(currentLocale, 'Property')

const facts = [
  detail.bedrooms != null ? { value: String(detail.bedrooms), label: translateLabel(currentLocale, 'Bedrooms') } : null,
  detail.bathrooms != null ? { value: String(detail.bathrooms), label: translateLabel(currentLocale, 'Bathrooms') } : null,
  detail.garages != null ? { value: String(detail.garages), label: translateLabel(currentLocale, 'Garages') } : null,
  detail.area ? { value: detail.area, label: translateLabel(currentLocale, 'Area') } : null,
].filter(Boolean)

const galleryId = `property-gallery-${detail.id}`
---

<article class="property-detail">
  {detail.photos.length > 0 && (
    <section class="property-detail__hero">
      <div class="property-gallery" id={galleryId} data-gallery>
        <div class="property-gallery__stage">
          <div class="property-gallery__swipe-layer" aria-hidden="true"></div>
          {detail.photos.map((photo, i) => (
            <figure
              class:list={['property-gallery__slide', { 'property-gallery__slide--active': i === 0 }]}
              data-slide
              data-index={i}
            >
              <img
                src={photo.url}
                alt={photo.alt ?? `${detail.title} photo ${i + 1}`}
                class="property-gallery__image"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
              <div class="property-gallery__overlay">
                <div class="property-gallery__badges">
                  <span class="property-gallery__status">{statusLabel}</span>
                  {detail.featured && <span class="property-gallery__featured">{translateLabel(currentLocale, 'Featured')}</span>}
                </div>
                <div class="property-gallery__meta">
                  <h1 class="property-gallery__title">{detail.title}</h1>
                  <div class="property-gallery__meta-row">
                    {detail.fullAddress && <p class="property-gallery__address">{detail.fullAddress}</p>}
                    {detail.price && <p class="property-gallery__price">{detail.price}</p>}
                  </div>
                </div>
              </div>
            </figure>
          ))}

          <button
            type="button"
            class="property-gallery__fullscreen"
            data-gallery-open
            aria-label={translateLabel(currentLocale, 'Open fullscreen gallery')}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="m21 3-7 7"/><path d="m3 21 7-7"/></svg>
            <span>{translateLabel(currentLocale, 'View fullscreen')}</span>
          </button>

          {detail.photos.length > 1 && (
            <>
              <button
                type="button"
                class="property-gallery__control property-gallery__control--prev"
                data-gallery-prev
                aria-label={translateLabel(currentLocale, 'Previous image')}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
              </button>
              <button
                type="button"
                class="property-gallery__control property-gallery__control--next"
                data-gallery-next
                aria-label={translateLabel(currentLocale, 'Next image')}
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </button>
            </>
          )}

          <div class="property-gallery__counter">
            <span data-gallery-current>1</span>
            <span>/</span>
            <span>{detail.photos.length}</span>
          </div>
        </div>

        {detail.photos.length >= 3 && (
          <div class="property-gallery__thumbs" role="tablist" aria-label={translateLabel(currentLocale, 'Property image thumbnails')}>
            {detail.photos.map((photo, i) => (
              <button
                type="button"
                class:list={['property-gallery__thumb', { 'property-gallery__thumb--active': i === 0 }]}
                data-gallery-thumb
                data-index={i}
                aria-label={`${translateLabel(currentLocale, 'View image')} ${i + 1}`}
                aria-selected={i === 0 ? 'true' : 'false'}
              >
                <img
                  src={photo.variants.thumbnail ?? photo.url}
                  alt=""
                  loading="lazy"
                  class="property-gallery__thumb-image"
                />
              </button>
            ))}
          </div>
        )}

        <dialog
          class="property-gallery-lightbox"
          data-gallery-lightbox
          aria-label={translateLabel(currentLocale, 'Fullscreen photo gallery')}
        >
          <div class="property-gallery-lightbox__shell">
            <button
              type="button"
              class="property-gallery-lightbox__close"
              data-gallery-close
              aria-label={translateLabel(currentLocale, 'Close gallery')}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>

            <div class="property-gallery-lightbox__stage" data-gallery-lightbox-stage>
              {detail.photos.map((photo, i) => (
                <figure
                  class:list={['property-gallery-lightbox__slide', { 'property-gallery-lightbox__slide--active': i === 0 }]}
                  data-lightbox-slide
                  data-index={i}
                >
                  <img
                    src={photo.url}
                    alt={photo.alt ?? `${detail.title} photo ${i + 1}`}
                    class="property-gallery-lightbox__image"
                    loading="lazy"
                  />
                </figure>
              ))}

              {detail.photos.length > 1 && (
                <>
                  <button
                    type="button"
                    class="property-gallery__control property-gallery__control--prev property-gallery__control--lightbox"
                    data-gallery-lightbox-prev
                    aria-label={translateLabel(currentLocale, 'Previous image')}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                  </button>
                  <button
                    type="button"
                    class="property-gallery__control property-gallery__control--next property-gallery__control--lightbox"
                    data-gallery-lightbox-next
                    aria-label={translateLabel(currentLocale, 'Next image')}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  </button>
                </>
              )}

              <div class="property-gallery__counter property-gallery__counter--lightbox">
                <span data-gallery-lightbox-current>1</span>
                <span>/</span>
                <span>{detail.photos.length}</span>
              </div>
            </div>

            {detail.photos.length >= 3 && (
              <div
                class="property-gallery-lightbox__thumbs"
                role="tablist"
                aria-label={translateLabel(currentLocale, 'Property image thumbnails')}
              >
                {detail.photos.map((photo, i) => (
                  <button
                    type="button"
                    class:list={['property-gallery-lightbox__thumb', { 'property-gallery-lightbox__thumb--active': i === 0 }]}
                    data-gallery-lightbox-thumb
                    data-index={i}
                    aria-label={`${translateLabel(currentLocale, 'View image')} ${i + 1}`}
                    aria-selected={i === 0 ? 'true' : 'false'}
                  >
                    <img
                      src={photo.variants.thumbnail ?? photo.url}
                      alt=""
                      loading="lazy"
                      class="property-gallery-lightbox__thumb-image"
                    />
                  </button>
                ))}
              </div>
            )}
          </div>
        </dialog>
      </div>
    </section>
  )}

  <div class="property-detail__content">
    <section class="property-detail__facts" aria-label={translateLabel(currentLocale, 'Property overview')}>
      {facts.map((fact) => fact && (
        <article class="property-detail__fact">
          <strong>{fact.value}</strong>
          <span>{fact.label}</span>
        </article>
      ))}
      <article class="property-detail__fact">
        <strong>{detail.propertyTypeLabel}</strong>
        <span>{translateLabel(currentLocale, 'Property type')}</span>
      </article>
    </section>

    {detail.description && (
      <section class="property-detail__narrative">
        <p class="property-detail__eyebrow">{translateLabel(currentLocale, 'Overview')}</p>
        <div class="property-detail__description" set:html={detail.description} />
      </section>
    )}
  </div>
</article>

<script is:inline>
  document.querySelectorAll('[data-gallery]').forEach((galleryEl) => {
    const gallery = galleryEl;
    const slides = Array.from(gallery.querySelectorAll('[data-slide]'));
    const thumbs = Array.from(gallery.querySelectorAll('[data-gallery-thumb]'));
    const lightboxSlides = Array.from(gallery.querySelectorAll('[data-lightbox-slide]'));
    const lightboxThumbs = Array.from(gallery.querySelectorAll('[data-gallery-lightbox-thumb]'));
    const currentEl = gallery.querySelector('[data-gallery-current]');
    const lightboxCurrentEl = gallery.querySelector('[data-gallery-lightbox-current]');
    const prev = gallery.querySelector('[data-gallery-prev]');
    const next = gallery.querySelector('[data-gallery-next]');
    const open = gallery.querySelector('[data-gallery-open]');
    const close = gallery.querySelector('[data-gallery-close]');
    const lightbox = gallery.querySelector('[data-gallery-lightbox]');
    const lightboxPrev = gallery.querySelector('[data-gallery-lightbox-prev]');
    const lightboxNext = gallery.querySelector('[data-gallery-lightbox-next]');
    const stage = gallery.querySelector('.property-gallery__stage');
    const lightboxStage = gallery.querySelector('[data-gallery-lightbox-stage]');

    let index = slides.findIndex((slide) => slide.classList.contains('property-gallery__slide--active'));
    if (index < 0) index = 0;
    let touchStartX = 0;
    let touchDeltaX = 0;
    let lightboxTouchStartX = 0;
    let lightboxTouchDeltaX = 0;

    if (stage) {
      stage.setAttribute('tabindex', '0');
    }

    if (lightboxStage) {
      lightboxStage.setAttribute('tabindex', '0');
    }

    const syncThumbState = (collection, activeClass) => {
      collection.forEach((thumb, thumbIndex) => {
        const active = thumbIndex === index;
        thumb.classList.toggle(activeClass, active);
        thumb.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    };

    const render = () => {
      slides.forEach((slide, slideIndex) => {
        slide.classList.toggle('property-gallery__slide--active', slideIndex === index);
      });

      lightboxSlides.forEach((slide, slideIndex) => {
        slide.classList.toggle('property-gallery-lightbox__slide--active', slideIndex === index);
      });

      syncThumbState(thumbs, 'property-gallery__thumb--active');
      syncThumbState(lightboxThumbs, 'property-gallery-lightbox__thumb--active');

      if (currentEl) currentEl.textContent = String(index + 1);
      if (lightboxCurrentEl) lightboxCurrentEl.textContent = String(index + 1);
    };

    const showPrev = () => {
      index = (index - 1 + slides.length) % slides.length;
      render();
    };

    const showNext = () => {
      index = (index + 1) % slides.length;
      render();
    };

    const openLightbox = () => {
      if (!(lightbox instanceof HTMLDialogElement)) return;
      if (!lightbox.open) {
        lightbox.showModal();
        document.documentElement.classList.add('property-gallery-lightbox-open');
      }
      lightboxStage?.focus();
      render();
    };

    const closeLightbox = () => {
      if (!(lightbox instanceof HTMLDialogElement) || !lightbox.open) return;
      lightbox.close();
      document.documentElement.classList.remove('property-gallery-lightbox-open');
      open?.focus();
    };

    if (slides.length > 1) {
      prev?.addEventListener('click', showPrev);
      next?.addEventListener('click', showNext);
      lightboxPrev?.addEventListener('click', showPrev);
      lightboxNext?.addEventListener('click', showNext);
    }

    open?.addEventListener('click', openLightbox);
    close?.addEventListener('click', closeLightbox);

    stage?.addEventListener('touchstart', (event) => {
      touchStartX = event.changedTouches[0]?.clientX ?? 0;
      touchDeltaX = 0;
    }, { passive: true });

    stage?.addEventListener('touchmove', (event) => {
      const currentX = event.changedTouches[0]?.clientX ?? touchStartX;
      touchDeltaX = currentX - touchStartX;
    }, { passive: true });

    stage?.addEventListener('touchend', () => {
      if (Math.abs(touchDeltaX) < 36) return;
      if (touchDeltaX < 0) {
        index = (index + 1) % slides.length;
      } else {
        index = (index - 1 + slides.length) % slides.length;
      }
      render();
      touchStartX = 0;
      touchDeltaX = 0;
    }, { passive: true });

    lightboxStage?.addEventListener('touchstart', (event) => {
      lightboxTouchStartX = event.changedTouches[0]?.clientX ?? 0;
      lightboxTouchDeltaX = 0;
    }, { passive: true });

    lightboxStage?.addEventListener('touchmove', (event) => {
      const currentX = event.changedTouches[0]?.clientX ?? lightboxTouchStartX;
      lightboxTouchDeltaX = currentX - lightboxTouchStartX;
    }, { passive: true });

    lightboxStage?.addEventListener('touchend', () => {
      if (Math.abs(lightboxTouchDeltaX) < 36) return;
      if (lightboxTouchDeltaX < 0) {
        showNext();
      } else {
        showPrev();
      }
      lightboxTouchStartX = 0;
      lightboxTouchDeltaX = 0;
    }, { passive: true });

    thumbs.forEach((thumb, thumbIndex) => {
      thumb.addEventListener('click', () => {
        index = thumbIndex;
        render();
      });
    });

    lightboxThumbs.forEach((thumb, thumbIndex) => {
      thumb.addEventListener('click', () => {
        index = thumbIndex;
        render();
      });
    });

    stage?.addEventListener('dblclick', openLightbox);

    gallery.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft' && slides.length > 1) {
        showPrev();
      }

      if (event.key === 'ArrowRight' && slides.length > 1) {
        showNext();
      }
    });

    lightbox?.addEventListener('click', (event) => {
      if (event.target === lightbox) {
        closeLightbox();
      }
    });

    lightbox?.addEventListener('cancel', (event) => {
      event.preventDefault();
      closeLightbox();
    });

    lightbox?.addEventListener('close', () => {
      document.documentElement.classList.remove('property-gallery-lightbox-open');
    });

    lightboxStage?.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft' && slides.length > 1) {
        event.preventDefault();
        showPrev();
      }

      if (event.key === 'ArrowRight' && slides.length > 1) {
        event.preventDefault();
        showNext();
      }

      if (event.key === 'Escape') {
        event.preventDefault();
        closeLightbox();
      }
    });

    render();
  });
</script>

<style>
  .property-detail {
    display: grid;
    gap: 1.5rem;
  }

  .property-detail__hero,
  .property-detail__content {
    background: var(--color-surface-strong);
    border: 1px solid rgba(22, 53, 76, 0.08);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    animation: property-panel-enter 460ms ease both;
  }

  .property-detail__content {
    animation-delay: 70ms;
  }

  .property-gallery {
    display: grid;
    gap: 0.75rem;
    padding: 0.6rem;
    background: rgba(22, 53, 76, 0.05);
  }

  .property-gallery__stage {
    position: relative;
    overflow: hidden;
    border-radius: calc(var(--radius-xl) - 0.5rem);
    min-height: clamp(26rem, 62vh, 40rem);
    background: #d8d4cf;
    outline: none;
  }

  .property-gallery__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transform: scale(1.018);
    transition: opacity 260ms ease, transform 520ms ease;
  }

  .property-gallery__slide--active {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
  }

  .property-gallery__swipe-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .property-gallery__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .property-gallery__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(1rem, 2vw, 1.5rem);
    background:
      linear-gradient(180deg, rgba(9, 26, 39, 0.22) 0%, rgba(9, 26, 39, 0) 34%, rgba(9, 26, 39, 0.74) 100%);
    color: var(--color-on-dark);
    pointer-events: none;
    z-index: 2;
  }

  .property-gallery__badges {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .property-gallery__status,
  .property-gallery__featured {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    backdrop-filter: blur(8px);
  }

  .property-gallery__status {
    background: rgba(9, 26, 39, 0.54);
    color: var(--color-on-dark);
  }

  .property-gallery__featured {
    background: rgba(216, 187, 137, 0.88);
    color: var(--color-primary);
  }

  .property-gallery__meta {
    display: grid;
    gap: 0.7rem;
  }

  .property-gallery__title {
    margin: 0;
    max-width: 14ch;
    font-family: var(--font-serif);
    font-size: clamp(2.3rem, 5vw, 4.8rem);
    line-height: 0.92;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .property-gallery__meta-row {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .property-gallery__address,
  .property-gallery__price {
    margin: 0;
  }

  .property-gallery__address {
    color: rgba(246, 242, 235, 0.86);
    font-size: var(--text-lg);
  }

  .property-gallery__price {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3vw, 2.9rem);
    line-height: 1;
    color: var(--color-gold);
    white-space: nowrap;
  }

  .property-gallery__control,
  .property-gallery__counter,
  .property-gallery__fullscreen {
    position: absolute;
    z-index: 3;
  }

  .property-gallery__control,
  .property-gallery__fullscreen,
  .property-gallery-lightbox__close {
    top: 50%;
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 999px;
    background: rgba(252, 250, 247, 0.84);
    color: var(--color-primary);
    cursor: pointer;
    box-shadow: var(--shadow-md);
    transition: transform var(--transition-base), background var(--transition-base);
  }

  .property-gallery__control {
    transform: translateY(-50%);
  }

  .property-gallery__control:hover {
    background: var(--color-surface-strong);
  }

  .property-gallery__fullscreen,
  .property-gallery-lightbox__close {
    top: 1rem;
    right: 1rem;
    gap: 0.45rem;
    width: auto;
    min-height: 3rem;
    padding: 0.75rem 0.95rem;
    transform: none;
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .property-gallery__fullscreen:hover,
  .property-gallery-lightbox__close:hover {
    background: var(--color-surface-strong);
    transform: translateY(-1px);
  }

  .property-gallery__fullscreen span {
    line-height: 1;
  }

  .property-gallery__control--prev {
    left: 1rem;
  }

  .property-gallery__control--next {
    right: 1rem;
  }

  .property-gallery__counter {
    top: 1rem;
    right: 11rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(9, 26, 39, 0.54);
    color: var(--color-on-dark);
    font-size: var(--text-sm);
    font-weight: 700;
    backdrop-filter: blur(8px);
  }

  .property-gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(4.5rem, 5.75rem));
    justify-content: start;
    gap: 0.5rem;
    padding: 0 0.15rem 0.15rem;
  }

  .property-gallery__thumb {
    border: 2px solid transparent;
    border-radius: calc(var(--radius-md) - 0.1rem);
    padding: 0;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.85);
    cursor: pointer;
    opacity: 0.82;
    box-shadow: var(--shadow-sm);
    transition: opacity var(--transition-base), transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .property-gallery__thumb:hover,
  .property-gallery__thumb--active {
    opacity: 1;
    transform: translateY(-2px);
    border-color: rgba(22, 53, 76, 0.22);
    box-shadow: var(--shadow-md);
  }

  .property-gallery-lightbox {
    width: min(100vw, 100%);
    max-width: none;
    height: 100vh;
    max-height: none;
    margin: 0;
    padding: 0;
    border: none;
    background: rgba(8, 20, 31, 0.96);
    color: var(--color-on-dark);
  }

  .property-gallery-lightbox::backdrop {
    background: rgba(8, 20, 31, 0.72);
    backdrop-filter: blur(6px);
  }

  .property-gallery-lightbox__shell {
    height: 100%;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: 1rem;
    padding: 1.25rem;
  }

  .property-gallery-lightbox__stage {
    position: relative;
    min-height: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background:
      radial-gradient(circle at top, rgba(214, 181, 115, 0.16), transparent 40%),
      rgba(10, 23, 35, 0.88);
    outline: none;
  }

  .property-gallery-lightbox__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    display: grid;
    place-items: center;
    padding: clamp(2rem, 5vw, 4.5rem);
    transition: opacity 220ms ease;
  }

  .property-gallery-lightbox__slide--active {
    opacity: 1;
    visibility: visible;
  }

  .property-gallery-lightbox__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .property-gallery__control--lightbox {
    background: rgba(252, 250, 247, 0.16);
    color: var(--color-on-dark);
    backdrop-filter: blur(12px);
  }

  .property-gallery__control--lightbox:hover {
    background: rgba(252, 250, 247, 0.26);
  }

  .property-gallery__counter--lightbox {
    right: auto;
    left: 1rem;
    background: rgba(252, 250, 247, 0.16);
    color: var(--color-on-dark);
  }

  .property-gallery-lightbox__close {
    position: absolute;
    z-index: 4;
    background: rgba(252, 250, 247, 0.16);
    color: var(--color-on-dark);
    backdrop-filter: blur(12px);
  }

  .property-gallery-lightbox__thumbs {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    padding: 0.1rem 0.1rem 0.35rem;
    scrollbar-width: thin;
  }

  .property-gallery-lightbox__thumb {
    flex: 0 0 7rem;
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--radius-md);
