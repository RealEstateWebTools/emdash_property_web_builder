---
import { createPwbClient } from '../lib/pwb/client'
import { formatPropertyCard } from '../lib/pwb/formatters'
import BaseLayout from '../layouts/BaseLayout.astro'
import PropertyGrid from '../components/PropertyGrid.astro'

const client = createPwbClient()
const [site, results] = await Promise.all([
  client.getSiteDetails(),
  client.searchProperties({ featured: 'true', per_page: 6 }),
])

const cards = results.data.map(formatPropertyCard)
---

<BaseLayout site={site}>
  <section class="hero">
    <h1>Find Your Dream Property</h1>
    <p>{site.meta_description}</p>
    <div class="hero__actions">
      <a href="/properties" class="btn btn-primary">Properties for Sale</a>
      <a href="/properties?mode=rental" class="btn btn-primary">Properties for Rent</a>
    </div>
  </section>

  {cards.length > 0 && (
    <section class="featured-section">
      <h2>Featured Properties</h2>
      <PropertyGrid cards={cards} />
      <div class="featured-section__cta">
        <a href="/properties" class="btn btn-primary">View All Properties</a>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem var(--spacing-page);
    background: var(--color-bg-soft);
  }
  .hero h1 { font-size: var(--text-3xl); margin-bottom: 1rem; }
  .hero p { font-size: var(--text-lg); color: var(--color-text-muted); margin-bottom: 2rem; }
  .hero__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .featured-section { padding: 3rem var(--spacing-page); }
  .featured-section h2 { font-size: var(--text-2xl); margin-bottom: 2rem; text-align: center; }
  .featured-section__cta { text-align: center; margin-top: 2rem; }
</style>
