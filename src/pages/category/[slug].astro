---
import CategoryPage from '../../components/pages/CategoryPage.astro'
import { DEFAULT_LOCALE } from '../../lib/locale'
import { loadTaxonomyTerm } from '../../lib/page-loaders'

const locale = Astro.currentLocale ?? DEFAULT_LOCALE
const { slug } = Astro.params
// Status must be set in route frontmatter — Astro 7 fixes the Response
// status before components render (see src/lib/page-loaders.ts).
const load = await loadTaxonomyTerm('category', slug)
if (load.status) Astro.response.status = load.status
---

{slug ? <CategoryPage locale={locale} slug={slug} term={load.term} /> : null}
