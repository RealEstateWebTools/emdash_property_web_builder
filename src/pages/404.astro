---
import BaseLayout from '../layouts/BaseLayout.astro'
import type { SiteDetails } from '../lib/pwb/types'

// Do not call the PWB backend on the 404 page — the backend may be
// unreachable and any error would appear in Worker logs on every 404 hit.
const site: SiteDetails = {
  id: 0,
  title: 'Property Search',
  meta_description: null,
  company_display_name: null,
  logo_url: null,
  default_currency: null,
  default_area_unit: null,
  ga4_measurement_id: null,
  gtm_container_id: null,
  og: {},
  twitter: {},
  json_ld: {},
  analytics: null,
}
---

<BaseLayout site={site} title="Page not found">
  <div class="not-found">
    <h1>404</h1>
    <p>The page you&rsquo;re looking for doesn&rsquo;t exist.</p>
    <a href="/">Go back home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 6rem var(--spacing-page, 1.5rem);
  }
  .not-found h1 {
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 700;
    color: var(--color-border, #e5e7eb);
    line-height: 1;
    margin-bottom: 1rem;
  }
  .not-found p {
    color: var(--color-text-muted, #6b7280);
    font-size: 1.125rem;
    margin-bottom: 1.5rem;
  }
  .not-found a {
    color: var(--color-primary, #1a4f8a);
    text-decoration: none;
    font-size: 0.9375rem;
  }
  .not-found a:hover {
    text-decoration: underline;
  }
</style>
