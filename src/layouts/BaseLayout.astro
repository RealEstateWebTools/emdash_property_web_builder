---
import { buildPageMeta } from '../lib/pwb/site-config'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import type { SiteDetails } from '../lib/pwb/types'
import {
  buildThemeStyleOverrides,
  DEFAULT_THEME_SETTINGS,
  PALETTE_KV_KEY,
  THEME_DENSITY_KV_KEY,
  THEME_HEADER_KV_KEY,
  THEME_MOTION_KV_KEY,
  THEME_SURFACE_KV_KEY,
  VALID_PALETTES,
  sanitizeThemeSettings,
  type Palette,
} from '../plugins/pwb-theme.js'
import { DEFAULT_LOCALE, translateBrand } from '../lib/locale'

interface Props {
  site: SiteDetails
  title?: string
  description?: string
  canonical?: string
  alternateLinks?: Array<{ locale: string; href: string }>
}

const { site, title, description, canonical, alternateLinks = [] } = Astro.props
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE
const localizedSiteTitle = translateBrand(currentLocale, site.company_display_name ?? site.title)
const meta = buildPageMeta(site, { locale: currentLocale, title, description, canonical })

// Palette resolution: admin panel setting > PUBLIC_PALETTE env var > 'default'
// The plugin stores its KV under key `plugin:pwb-theme:<key>` in the options table.
let themeSettings = DEFAULT_THEME_SETTINGS
const db = Astro.locals.emdash?.db
if (db) {
  try {
    const rows = await (db as any)
      .selectFrom('options')
      .select(['name', 'value'])
      .where('name', 'in', [
        `plugin:pwb-theme:${PALETTE_KV_KEY}`,
        `plugin:pwb-theme:${THEME_DENSITY_KV_KEY}`,
        `plugin:pwb-theme:${THEME_SURFACE_KV_KEY}`,
        `plugin:pwb-theme:${THEME_MOTION_KV_KEY}`,
        `plugin:pwb-theme:${THEME_HEADER_KV_KEY}`,
      ])
      .execute()

    const rawSettings = Object.fromEntries(
      rows.map((row: { name: string; value: unknown }) => {
        const key = row.name.split(':').slice(-1)[0]
        const parsed = typeof row.value === 'string' ? JSON.parse(row.value) : null
        return [key, parsed]
      }),
    )
    themeSettings = sanitizeThemeSettings({
      palette: rawSettings.palette,
      density: rawSettings.density,
      surface: rawSettings.surface,
      motion: rawSettings.motion,
      header: rawSettings.header,
    })
  } catch {
    // Plugin not yet installed or DB unavailable — fall through to env var
  }
}
if (themeSettings.palette === 'default') {
  const envPalette = import.meta.env.PUBLIC_PALETTE ?? 'default'
  if ((VALID_PALETTES as readonly string[]).includes(envPalette)) {
    themeSettings = { ...themeSettings, palette: envPalette as Palette }
  }
}

const palette = themeSettings.palette
const paletteHref = palette !== 'default' ? `/styles/palettes/${palette}.css` : null
const themeClass = palette !== 'default' ? `theme-${palette}` : undefined
const themeOverrides = buildThemeStyleOverrides(themeSettings)
---

<!doctype html>
<html lang={currentLocale} class={themeClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.title}</title>
    {meta.description && <meta name="description" content={meta.description} />}
    {meta.canonical && <link rel="canonical" href={meta.canonical} />}
    {alternateLinks.map(({ locale, href }) => (
      <link rel="alternate" hreflang={locale} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.url.origin).href} />

    <!-- PWB API URL for client-side fetch (contact form) -->
    <meta name="pwb-api-url" content={import.meta.env.PWB_API_URL} />

    <!-- Open Graph -->
    {Object.entries(meta.og).map(([property, content]) => (
      <meta property={property} content={content} />
    ))}

    <!-- Twitter -->
    {Object.entries(meta.twitter).map(([name, content]) => (
      <meta name={name} content={content} />
    ))}

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(meta.jsonLd)} />

    <!-- Google Analytics 4 -->
    {site.analytics?.ga4_id && (
      <>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${site.analytics.ga4_id}`}
        />
        <script define:vars={{ ga4Id: site.analytics.ga4_id }}>
          window.dataLayer = window.dataLayer || []
          function gtag() { dataLayer.push(arguments) }
          gtag('js', new Date())
          gtag('config', ga4Id)
        </script>
      </>
    )}

    <link rel="stylesheet" href="/styles/theme.css" />
    {paletteHref && <link rel="stylesheet" href={paletteHref} />}
    {themeOverrides && <style is:inline>{themeOverrides}</style>}
  </head>
  <body>
    <SiteHeader site={site} />
    <main>
      <slot />
    </main>
    <SiteFooter siteTitle={localizedSiteTitle} />
  </body>
</html>
