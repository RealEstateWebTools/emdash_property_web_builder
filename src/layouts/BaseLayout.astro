---
import { buildPageMeta } from '../lib/pwb/site-config'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import type { SiteDetails } from '../lib/pwb/types'
import type { BreadcrumbItem } from 'emdash'
import {
  applySiteProfileToSite,
  readSiteProfileSettingsFromDb,
  type SiteProfileSettings,
} from '../lib/site-profile.js'
import {
  buildThemeStyleOverrides,
  DEFAULT_THEME_SETTINGS,
  PALETTE_KV_KEY,
  THEME_DENSITY_KV_KEY,
  THEME_HEADER_KV_KEY,
  THEME_MOTION_KV_KEY,
  THEME_SURFACE_KV_KEY,
  VALID_PALETTES,
  sanitizeThemeSettings,
  type Palette,
} from '../plugins/pwb-theme.js'
import { DEFAULT_LOCALE, translateBrand } from '../lib/locale'

interface Props {
  site: SiteDetails
  title?: string
  description?: string
  canonical?: string
  alternateLinks?: Array<{ locale: string; href: string }>
  /** Override site name in page titles (e.g. translateBrand(locale, "My Blog") for blog pages). */
  siteTitle?: string
  /** Breadcrumb trail. undefined = no breadcrumbs rendered; [] = empty (opt-out); non-empty = rendered. */
  breadcrumbs?: BreadcrumbItem[]
}

const { site, title, description, canonical, alternateLinks = [], siteTitle, breadcrumbs } = Astro.props
const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE

// Palette resolution: admin panel setting > PUBLIC_PALETTE env var > 'default'
// The plugin stores its KV under key `plugin:pwb-theme:<key>` in the options table.
let themeSettings = DEFAULT_THEME_SETTINGS
let siteProfile: SiteProfileSettings
const db = Astro.locals.emdash?.db
siteProfile = await readSiteProfileSettingsFromDb(db)
if (db) {
  try {
    const rows = await (db as any)
      .selectFrom('options')
      .select(['name', 'value'])
      .where('name', 'in', [
        `plugin:pwb-theme:${PALETTE_KV_KEY}`,
        `plugin:pwb-theme:${THEME_DENSITY_KV_KEY}`,
        `plugin:pwb-theme:${THEME_SURFACE_KV_KEY}`,
        `plugin:pwb-theme:${THEME_MOTION_KV_KEY}`,
        `plugin:pwb-theme:${THEME_HEADER_KV_KEY}`,
      ])
      .execute()

    const rawSettings = Object.fromEntries(
      rows.map((row: { name: string; value: unknown }) => {
        const key = row.name.split(':').slice(-1)[0]
        const parsed = typeof row.value === 'string' ? JSON.parse(row.value) : null
        return [key, parsed]
      }),
    )
    themeSettings = sanitizeThemeSettings({
      palette: rawSettings.palette,
      density: rawSettings.density,
      surface: rawSettings.surface,
      motion: rawSettings.motion,
      header: rawSettings.header,
    })
  } catch {
    // Plugin not yet installed or DB unavailable — fall through to env var
  }
}
if (themeSettings.palette === 'default') {
  const envPalette = import.meta.env.PUBLIC_PALETTE ?? 'default'
  if ((VALID_PALETTES as readonly string[]).includes(envPalette)) {
    themeSettings = { ...themeSettings, palette: envPalette as Palette }
  }
}

const palette = themeSettings.palette
const paletteHref = palette !== 'default' ? `/styles/palettes/${palette}.css` : null
const themeClass = palette !== 'default' ? `theme-${palette}` : undefined
const themeOverrides = buildThemeStyleOverrides(themeSettings)
const localizedSiteTitleFromSite = translateBrand(currentLocale, site.company_display_name ?? site.title)
const siteWithProfile = applySiteProfileToSite(site, siteProfile)
const localizedSiteTitle = translateBrand(currentLocale, siteWithProfile.company_display_name ?? siteWithProfile.title) || localizedSiteTitleFromSite
const meta = buildPageMeta(siteWithProfile, { locale: currentLocale, title, description, canonical, siteTitle })
---

<!doctype html>
<html lang={currentLocale} class={themeClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <title>{meta.title}</title>
    {meta.description && <meta name="description" content={meta.description} />}
    {meta.canonical && <link rel="canonical" href={meta.canonical} />}
    {alternateLinks.map(({ locale, href }) => (
      <link rel="alternate" hreflang={locale} href={href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.url.origin).href} />

    <!-- Open Graph -->
    {Object.entries(meta.og).map(([property, content]) => (
      <meta property={property} content={content} />
    ))}

    <!-- Twitter -->
    {Object.entries(meta.twitter).map(([name, content]) => (
      <meta name={name} content={content} />
    ))}

    <!-- JSON-LD: site -->
    <script type="application/ld+json" set:html={JSON.stringify(meta.jsonLd)} />

    <!-- JSON-LD: BreadcrumbList -->
    {breadcrumbs && breadcrumbs.length > 1 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((crumb, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: crumb.name,
          item: new URL(crumb.url, Astro.url.origin).href,
        })),
      })} />
    )}

    <!-- Google Analytics 4 -->
    {site.analytics?.ga4_id && (
      <>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${site.analytics.ga4_id}`}
        />
        <script define:vars={{ ga4Id: site.analytics.ga4_id }}>
          window.dataLayer = window.dataLayer || []
          function gtag() { dataLayer.push(arguments) }
          gtag('js', new Date())
          gtag('config', ga4Id)
        </script>
      </>
    )}

    <link rel="stylesheet" href="/styles/theme.css" />
    {paletteHref && <link rel="stylesheet" href={paletteHref} />}
    {themeOverrides && <style is:inline>{themeOverrides}</style>}
    <slot name="head" />
  </head>
  <body>
    <SiteHeader site={siteWithProfile} siteProfile={siteProfile} />
    {breadcrumbs && breadcrumbs.length > 0 && (
      <nav aria-label="Breadcrumb" class="breadcrumb-nav">
        <ol class="breadcrumb-list">
          {breadcrumbs.map((crumb, i) => (
            <li class="breadcrumb-item">
              {i < breadcrumbs.length - 1
                ? <a href={crumb.url} class="breadcrumb-link">{crumb.name}</a>
                : <span aria-current="page" class="breadcrumb-current">{crumb.name}</span>
              }
            </li>
          ))}
        </ol>
      </nav>
    )}
    <main>
      <slot />
    </main>
    <SiteFooter siteTitle={localizedSiteTitle} siteProfile={siteProfile} />
  </body>
</html>

<style>
  .breadcrumb-nav {
    width: min(100%, 76rem);
    margin: 0 auto;
    padding: 1rem var(--spacing-page) 0;
  }

  .breadcrumb-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
  }

  .breadcrumb-item {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .breadcrumb-item:not(:last-child)::after {
    content: '/';
    color: rgba(22, 53, 76, 0.32);
  }

  .breadcrumb-link,
  .breadcrumb-current {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.55rem;
    border-radius: 999px;
    text-decoration: none;
  }

  .breadcrumb-link {
    color: var(--color-text-soft);
    background: rgba(22, 53, 76, 0.04);
  }

  .breadcrumb-link:hover {
    color: var(--color-primary);
    background: rgba(22, 53, 76, 0.08);
  }

  .breadcrumb-current {
    color: var(--color-primary);
    background: rgba(185, 138, 78, 0.12);
    max-width: min(100%, 36rem);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
