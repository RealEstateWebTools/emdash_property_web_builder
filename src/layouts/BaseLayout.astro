---
import { buildPageMeta } from '../lib/pwb/site-config'
import SiteHeader from '../components/SiteHeader.astro'
import SiteFooter from '../components/SiteFooter.astro'
import type { SiteDetails } from '../lib/pwb/types'
import { VALID_PALETTES, PALETTE_KV_KEY, type Palette } from '../plugins/pwb-theme.js'

interface Props {
  site: SiteDetails
  title?: string
  description?: string
  canonical?: string
}

const { site, title, description, canonical } = Astro.props
const meta = buildPageMeta(site, { title, description, canonical })

// Palette resolution: admin panel setting > PUBLIC_PALETTE env var > 'default'
// The plugin stores its KV under key `plugin:pwb-theme:<key>` in the options table.
let palette: Palette = 'default'
const db = Astro.locals.emdash?.db
if (db) {
  try {
    const row = await (db as any)
      .selectFrom('options')
      .select('value')
      .where('name', '=', `plugin:pwb-theme:${PALETTE_KV_KEY}`)
      .executeTakeFirst()
    // Values are stored as JSON by OptionsRepository, so parse before comparing.
    const raw: unknown = row?.value
    const parsed: unknown = typeof raw === 'string' ? JSON.parse(raw) : null
    if (typeof parsed === 'string' && (VALID_PALETTES as readonly string[]).includes(parsed)) {
      palette = parsed as Palette
    }
  } catch {
    // Plugin not yet installed or DB unavailable — fall through to env var
  }
}
if (palette === 'default') {
  const envPalette = import.meta.env.PUBLIC_PALETTE ?? 'default'
  if ((VALID_PALETTES as readonly string[]).includes(envPalette)) {
    palette = envPalette as Palette
  }
}

const paletteHref = palette !== 'default' ? `/styles/palettes/${palette}.css` : null
const themeClass = palette !== 'default' ? `theme-${palette}` : undefined
---

<!doctype html>
<html lang="en" class={themeClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{meta.title}</title>
    {meta.description && <meta name="description" content={meta.description} />}
    {meta.canonical && <link rel="canonical" href={meta.canonical} />}

    <!-- PWB API URL for client-side fetch (contact form) -->
    <meta name="pwb-api-url" content={import.meta.env.PWB_API_URL} />

    <!-- Open Graph -->
    {Object.entries(meta.og).map(([property, content]) => (
      <meta property={property} content={content} />
    ))}

    <!-- Twitter -->
    {Object.entries(meta.twitter).map(([name, content]) => (
      <meta name={name} content={content} />
    ))}

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(meta.jsonLd)} />

    <!-- Google Analytics 4 -->
    {site.analytics?.ga4_id && (
      <>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${site.analytics.ga4_id}`}
        />
        <script define:vars={{ ga4Id: site.analytics.ga4_id }}>
          window.dataLayer = window.dataLayer || []
          function gtag() { dataLayer.push(arguments) }
          gtag('js', new Date())
          gtag('config', ga4Id)
        </script>
      </>
    )}

    <link rel="stylesheet" href="/styles/theme.css" />
    {paletteHref && <link rel="stylesheet" href={paletteHref} />}
  </head>
  <body>
    <SiteHeader site={site} />
    <main>
      <slot />
    </main>
    <SiteFooter siteTitle={site.company_display_name ?? site.title} />
  </body>
</html>
